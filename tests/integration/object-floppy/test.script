# M7e integration: `floppy` object class.
# fd0 is loaded with a System 6.0.8 disk, fd1 is empty. The script
# walks both drives, verifies present/disk reflect the load state,
# exercises eject() and confirms present flips to false afterwards.

run 50000

# Top-level floppy.
eval floppy
eval floppy.type
eval floppy.sel

# Drives collection.
eval floppy.drives

# Drive 0: populated.
eval floppy.drives[0].index
eval floppy.drives[0].present
eval floppy.drives[0].disk
eval floppy.drives[0].track
eval floppy.drives[0].side
eval floppy.drives[0].motor_on

# Drive 1: empty.
eval floppy.drives[1].index
eval floppy.drives[1].present
eval floppy.drives[1].disk

# Eject drive 0 — present must flip to false, disk to empty string.
echo $(floppy.drives[0].eject())
eval floppy.drives[0].present
eval floppy.drives[0].disk

# Ejecting an already-empty drive is an error (the method is honest
# rather than silently no-op'ing — the harness shouldn't fail on
# this since echo $() prints the error and continues).

quit
