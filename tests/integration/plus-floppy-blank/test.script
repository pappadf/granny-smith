# Mac Plus — blank floppy: create, mount as 2nd drive, init dialog, eject.
#
# Boots System 6.0.8 (internal drive), then:
#   1. storage.fd_create writes a blank 800K image into WORK_DIR.
#   2. Insert it into the external drive (drive[1]) — two drives live at once.
#   3. System 6 can't read the unformatted disk and puts up the
#      "This is not a Macintosh disk: Do you want to initialize it?" dialog
#      (Eject / One-Sided / Two-Sided) — matched pixel-exact.
#   4. Click Eject; the blank leaves drive[1] (present → false) and the
#      desktop is clean again — matched pixel-exact.
#
# Instruction-exact budgets keep every frame reproducible (verified
# identical across runs). Mouse coords are Mac global (512x342).

# Create the blank floppy before booting far — fd_create is a host-side
# image op, independent of guest state.
assert storage.fd_create("${$WORK_DIR}/blank.dsk") "fd_create failed"

# Boot to the System Tools desktop.
scheduler.run 30000000

# Insert the blank into the external drive. System 6 spins it up, fails to
# mount, and offers to initialize it.
machine.floppy.drive[1].insert "$WORK_DIR/blank.dsk" true
scheduler.run 20000000
assert machine.floppy.drive[1].present "blank floppy not present in drive 1"
machine.screen.match init-dialog.png

# Click "Eject" (leftmost button) — dismiss without initializing.
machine.adb.mouse.move 157 155
scheduler.run 2000000
machine.adb.mouse.click true
scheduler.run 2000000
machine.adb.mouse.click false
scheduler.run 20000000

# The blank is ejected and the desktop is back.
assert machine.floppy.drive[1].present == false "blank floppy still present after Eject"
machine.screen.match desktop-after-eject.png

quit
