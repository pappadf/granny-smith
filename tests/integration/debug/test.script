# Integration test: Debug tooling — `find` family (shell v2).
#
# `find.{str|bytes|word|long}` return a V_LIST of match addresses
# (shell v2 §6.1); failures return V_ERROR. This script asserts on the
# typed results and echoes stable markers that run.sh greps.

# === find: introspection ================================================

# methods("find") lists the four sub-command methods this script
# exercises.
echo "${methods("find")}"

# === find.str: ASCII search =============================================

# "Apple" appears in the Plus ROM (which is mirrored at 0x400000).
# Restrict the scan to the primary mirror so the expected hit count is
# stable.
let hits = find.str("Apple", 0x400000, 0x440000)
assert len($hits) > 0 "find.str should locate 'Apple' in the ROM mirror"
echo "str-first=${$hits[0]:08x}"
echo "str-count=${len($hits)}"

# Bounded scan (start + count window).
let windowed = find.str("Apple", 0x400000, 0x400000 + 0x40000 - 1)
assert len($windowed) == len($hits) "windowed scan should see the same hits"

# Empty pattern is a typed error, not a silent no-op.
assert try(find.str("", 0x400000, 0x440000), none) == none "empty pattern must error"

# === find.bytes: hex-byte-sequence search ===============================

# Search for NOP (4E 71) in the mapped address range.
let nops = find.bytes("4E 71", 0x400000, 0x440000)
assert len($nops) > 0 "find.bytes should hit 68K NOPs"
echo "nop-count=${len($nops)}"

# Non-hex token is rejected.
assert try(find.bytes("ZZ"), none) == none "non-hex byte token must error"

# === find.word / find.long: big-endian value search =====================

# "Apple" begins with bytes 41 70 ('A','p'), so word 0x4170 hits where
# "Apple" starts — same location the str test already asserts.
# Probe a window pinned at the known str hit so the first word/long
# match is exactly that address (0x4170 also occurs elsewhere in ROM).
let w = find.word(0x4170, $hits[0], $hits[0] + 3)
assert $w[0] == $hits[0] "find.word should hit at the str offset"
echo "word-first=${$w[0]:08x}"

let l = find.long(0x4170706C, $hits[0], $hits[0] + 7)
assert $l[0] == $hits[0] "find.long should hit at the str offset"
echo "long-first=${$l[0]:08x}"

# Values exceeding 16 bits must be rejected — not silently truncated.
assert try(find.word(0x10000, 0x400000, 0x440000), none) == none "16-bit overflow must error"

# Backwards range is rejected.
assert try(find.str("Apple", 0x500000, 0x400000), none) == none "backwards range must error"

# === format specs in ${expr:fmt} ========================================
#
# These exercises pin down the supported specs (decimal, hex,
# width-padded hex, force-string) so we don't regress them.

echo "${0xab:x}"
echo "${0xab:08x}"
echo "[${0xab:8X}]"
echo "${0xab:d}"
echo "[${42:5d}]"
echo "${"hello":s}"
echo "fmt-marker[${0xab:08x}]"

# === indexed-child access ===============================================
#
# Reading an empty indexed slot is a typed error (script-abort without
# try); reading the index-less collection yields the entries list.

debug.breakpoints.clear
assert try(debug.breakpoints[42], none) == none "empty slot read must error"
assert len(debug.breakpoints.entries) == 0 "cleared collection reads as empty list"

# === debug.disasm with explicit address =================================
#
# `debug.disasm` accepts an optional starting address. The two-arg form
# `disasm <addr> <count>` lets you disassemble at an arbitrary address
# without first moving PC. The address below is in the Plus ROM that
# this test boots against.

debug.disasm 0x400090 3

quit
