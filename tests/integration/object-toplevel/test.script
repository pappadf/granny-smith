# M8 integration: network.appletalk + mouse top-level objects.
# Both are exercised through the new tree paths and through the legacy
# command shims to verify they share state.

run 50000

# Tree shape.
eval network
network.appletalk
network.appletalk.shares
network.appletalk.printer
eval mouse

# Initially the shares table is empty and the printer is disabled.
network.appletalk.printer.enabled
network.appletalk.printer.name

# Add a share via the new method, observe it via the legacy command.
# Use /tmp because atalk_share_add stat()s the directory; /tmp exists
# both in the dev container (/workspaces/granny-smith) and in CI
# (/__w/granny-smith/granny-smith) so the path is portable.
echo $(network.appletalk.shares.add("docs", "/tmp"))
atalk-share-list
network.appletalk.shares[0].name
network.appletalk.shares[0].path
network.appletalk.shares[0].vol_id

# Add via the legacy command, observe via the new tree.
network.appletalk.shares.add demo /tmp
network.appletalk.shares[1].name

# Remove via the new tree's per-entry method, verify legacy list reflects it.
echo $(network.appletalk.shares[0].remove())
atalk-share-list

# Printer enable/disable via the new methods.
echo $(network.appletalk.printer.enable("Test LaserWriter"))
network.appletalk.printer.enabled
network.appletalk.printer.name
echo $(network.appletalk.printer.disable())
network.appletalk.printer.enabled

# Mouse methods. Plus is a non-ADB machine with no MAE, so move()
# falls through to the global write path via set_mouse_default.
echo $(mouse.move(100, 200))
echo $(mouse.click(true))
echo $(mouse.click(false))
echo $(mouse.trace(true))
echo $(mouse.trace(false))

quit
