# IIcx + Display Card 8•24 GC — boot System 6.0.8 to the Finder desktop.
#
# The 8•24 GC is a super-slot (32-bit) card: with 32-bit QuickDraw present the
# decl-ROM SecondaryInit swaps the video sResource to its 32-bit variant, so
# ScrnBase moves to the super-slot DRAM aperture (NuBus 0x9C011400 = p->dram +
# 0x11400, stride 1024, 1 bpp) — that is where QuickDraw draws the desktop and
# what the card surfaces to the host display.  (The standard-slot VRAM only ever
# holds the early "Welcome to Macintosh" startup screen, before the swap.)
machine.nubus.video_card = "824gc"
machine.boot "iicx" 8192
machine.rom.reload

# Boot device: the System 6.0.8 HD with the 8•24 GC drivers.  A stable Finder
# desktop is reached well before 200M instr.
machine.scsi.attach_hd "../../data/systems/system_6_0_8_20mb_8_24gc.img" 0
scheduler.run 200000000

# The card that booted into the IIcx video slot ($9) is the 8•24 GC.
assert ${machine.nubus.slot[9].card.name == "Apple Macintosh Display Card 8•24 GC"} "slot $9 card != 8•24 GC"
assert ${machine.screen.width == 640}  "boot: screen width != 640"
assert ${machine.screen.height == 480} "boot: screen height != 480"

# The 1-bpp B&W Finder desktop (menu bar + Macintosh HD window + Trash), booted
# through the genuine decl-ROM video driver, pixel-exact.
machine.screen.match finder-824gc-640x480-1bpp.png

quit
