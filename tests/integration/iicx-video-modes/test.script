# Integration test: IIcx Video Modes
#
# Two axes of coverage, both driven by full cold-boots — no in-place
# mode changes, no OS patching.
#
# 1. **Depths.** Boot the IIcx with the System 7.0.1 floppy at 13" RGB
#    (sense $6) at 1, 2, 4, and 8 bpp.  Each depth is a separate cold
#    boot: PRAM is seeded with the slot-9 sPRAMRec values that name
#    the desired (monitor variant, depth) sResource on the Apple
#    Macintosh Display Card 8•24 (JMFB), then Mac OS boots and the
#    Slot Manager picks up the seeded mode at GET_SLOT_DEPTH time
#    (boot ROM $40800820 → $408009F6).  Seeded values:
#
#      $00       = $A8                    low-PRAM validator
#      $0C..$0F  = 'NuMc' ($4E754D63)     XPRAM validator
#      $46..$47  = $0027                  BoardID = JMFB
#      $48       = spDepth (varies)       savedMode  = $80/$81/$82/$83
#      $49..$4A  = $B6 / $B6              savedSRsrcID, savedRawSRsrcID
#                                         (= "Mac Hi-Res Display" — the
#                                          ACTIVE Bx sister for 13" RGB
#                                          per Apple-341-0868-vrom.asm
#                                          §6b row $B6)
#      $4B..$4D  = $00 / $00 / $00        specialFlag / clock / pad
#
#    Both validators are required: without $00=$A8 the boot ROM's
#    _InitUtil zeroes XPRAM and the seed is lost; without 'NuMc' the
#    XPRAM init runs even when low-PRAM passes (see docs/pram.md §3).
#    spDepth $80/$81/$82/$83 = 1/2/4/8 bpp — the 4 ACTIVE entries on
#    sRsrcID $B6.
#
#    24/32 bpp is intentionally NOT covered.  On the JMFB, 32bpp lives
#    only in the INACTIVE Ax sister sResources (e.g. $A6 spDepth4) and
#    `_SlotManager $06 sReadFHeader` rejects them — meaning a real
#    user's "Millions of Colors" pick on this card never persisted
#    across a reboot.  Reaching 32bpp from a test would require an OS
#    patch (the abandoned `screen.set_video_mode` route) and is out
#    of scope here.
#
# 2. **Resolutions.** Cold-boot the IIcx with no boot media, vary
#    `nubus.video_sense` per monitor type (12" RGB / 15" Portrait B&W
#    / 21" RGB Kong), and verify the JMFB driver picks the correct
#    mode-list sRsrc and the framebuffer ends up at the matching
#    pixel dimensions.  Anchored at the boot ROM's "insert disk"
#    floppy/? icon — Mac OS isn't loaded for these because we're
#    testing what the boot ROM + JMFB driver agree on without OS
#    involvement.  See JMFBPrimaryInit.a:78-95 for the sense table
#    and src/core/peripherals/nubus/cards/jmfb.c monitor_for_sense()
#    for the (sense -> width, height) mapping.
#
# Why screen.checksum + assert instead of screen.match for >1bpp:
#   screen.match is hard-coded to 1bpp in debug.c — extending its
#   PNG-load path to compare in RGBA space is more refactor than this
#   test warrants.  screen.checksum is deterministic per (VRAM, format,
#   stride) and gives equivalent regression coverage at non-1bpp
#   depths.  PNG references for 2/4/8bpp are kept alongside for
#   human inspection but aren't byte-compared by the test runner.

# === Helpers ==================================================================
# Same boot-to-Finder budget as tests/integration/iicx-floppy.

# === Depth sweep — one cold boot per (13" RGB, depth) =========================

# --- 1 bpp (spDepth $80) ---
machine.boot "iicx" 8192
rom.reload
floppy.drives[0].insert "../../data/systems/System_7_0_1.image"
nubus.video_sense = 0x6
rtc.pram_write 0x00 0xa8
rtc.pram_write 0x0c 0x4e
rtc.pram_write 0x0d 0x75
rtc.pram_write 0x0e 0x4d
rtc.pram_write 0x0f 0x63
rtc.pram_write 0x46 0x00
rtc.pram_write 0x47 0x27
rtc.pram_write 0x48 0x80
rtc.pram_write 0x49 0xb6
rtc.pram_write 0x4a 0xb6
rtc.pram_write 0x4b 0x00
rtc.pram_write 0x4c 0x00
rtc.pram_write 0x4d 0x00
scheduler.run 250000000
assert ${machine.id == "iicx"} "machine.id != iicx"
assert ${screen.width == 640}  "1bpp screen.width != 640"
assert ${screen.height == 480} "1bpp screen.height != 480"
assert ${rtc.pram_read(0x48) == 0x80} "1bpp savedMode rewritten by ROM"
assert ${memory.peek.l(0xf9200208) == 0x80} "1bpp CLUTPBCR != 0x80"
assert ${memory.peek.l(0xf920000c) == 0x14} "1bpp RowWords != 0x14"
screen.match finder-13in_rgb-640x480-1bpp.png

# --- 2 bpp (spDepth $81) ---
machine.boot "iicx" 8192
rom.reload
floppy.drives[0].insert "../../data/systems/System_7_0_1.image"
nubus.video_sense = 0x6
rtc.pram_write 0x00 0xa8
rtc.pram_write 0x0c 0x4e
rtc.pram_write 0x0d 0x75
rtc.pram_write 0x0e 0x4d
rtc.pram_write 0x0f 0x63
rtc.pram_write 0x46 0x00
rtc.pram_write 0x47 0x27
rtc.pram_write 0x48 0x81
rtc.pram_write 0x49 0xb6
rtc.pram_write 0x4a 0xb6
rtc.pram_write 0x4b 0x00
rtc.pram_write 0x4c 0x00
rtc.pram_write 0x4d 0x00
scheduler.run 250000000
assert ${rtc.pram_read(0x48) == 0x81}     "2bpp savedMode rewritten by ROM"
assert ${memory.peek.l(0xf9200208) == 0x88} "2bpp CLUTPBCR != 0x88"
assert ${memory.peek.l(0xf920000c) == 0x28} "2bpp RowWords != 0x28"
assert ${screen.checksum() == 130002408}    "2bpp Finder screen.checksum mismatch"

# --- 4 bpp (spDepth $82) ---
machine.boot "iicx" 8192
rom.reload
floppy.drives[0].insert "../../data/systems/System_7_0_1.image"
nubus.video_sense = 0x6
rtc.pram_write 0x00 0xa8
rtc.pram_write 0x0c 0x4e
rtc.pram_write 0x0d 0x75
rtc.pram_write 0x0e 0x4d
rtc.pram_write 0x0f 0x63
rtc.pram_write 0x46 0x00
rtc.pram_write 0x47 0x27
rtc.pram_write 0x48 0x82
rtc.pram_write 0x49 0xb6
rtc.pram_write 0x4a 0xb6
rtc.pram_write 0x4b 0x00
rtc.pram_write 0x4c 0x00
rtc.pram_write 0x4d 0x00
scheduler.run 250000000
assert ${rtc.pram_read(0x48) == 0x82}     "4bpp savedMode rewritten by ROM"
assert ${memory.peek.l(0xf9200208) == 0x90} "4bpp CLUTPBCR != 0x90"
assert ${memory.peek.l(0xf920000c) == 0x50} "4bpp RowWords != 0x50"
assert ${screen.checksum() == -1064842012} "4bpp Finder screen.checksum mismatch"

# --- 8 bpp (spDepth $83) ---
machine.boot "iicx" 8192
rom.reload
floppy.drives[0].insert "../../data/systems/System_7_0_1.image"
nubus.video_sense = 0x6
rtc.pram_write 0x00 0xa8
rtc.pram_write 0x0c 0x4e
rtc.pram_write 0x0d 0x75
rtc.pram_write 0x0e 0x4d
rtc.pram_write 0x0f 0x63
rtc.pram_write 0x46 0x00
rtc.pram_write 0x47 0x27
rtc.pram_write 0x48 0x83
rtc.pram_write 0x49 0xb6
rtc.pram_write 0x4a 0xb6
rtc.pram_write 0x4b 0x00
rtc.pram_write 0x4c 0x00
rtc.pram_write 0x4d 0x00
scheduler.run 250000000
assert ${rtc.pram_read(0x48) == 0x83}     "8bpp savedMode rewritten by ROM"
assert ${memory.peek.l(0xf9200208) == 0x98} "8bpp CLUTPBCR != 0x98"
assert ${memory.peek.l(0xf920000c) == 0xa0} "8bpp RowWords != 0xa0"
assert ${screen.checksum() == -456393471} "8bpp Finder screen.checksum mismatch"

# === Resolution sweep — cold-boot per monitor sense ===========================
# Anchor at the boot ROM "insert disk" floppy/? icon at each
# resolution; Mac OS isn't relevant here because the JMFB driver's
# resolution choice is fixed by the sense lines at PrimaryInit time.
# Per-resolution boot uses the same 335 M cycle budget as
# tests/integration/iicx-boot.

# === 12" RGB / Rubik (sense 0x2) — 512x384 ===
nubus.video_sense = 0x2
machine.boot "iicx" 8192
rom.reload
scheduler.run 335000000
assert ${screen.width == 512}  "12in_rgb width != 512"
assert ${screen.height == 384} "12in_rgb height != 384"
assert ${memory.peek.l(0xf920000c) == 0x10} "12in_rgb 1bpp RowWords != 0x10"
screen.match floppy-12in_rgb-512x384-1bpp.png

# === 15" Portrait B&W (sense 0x1) — 640x870 ===
nubus.video_sense = 0x1
machine.boot "iicx" 8192
rom.reload
scheduler.run 335000000
assert ${screen.width == 640}  "15in_bw width != 640"
assert ${screen.height == 870} "15in_bw height != 870"
assert ${memory.peek.l(0xf920000c) == 0x14} "15in_bw 1bpp RowWords != 0x14"
screen.match floppy-15in_bw-640x870-1bpp.png

# === 21" RGB / Kong (sense 0x0) — 1152x870 ===
nubus.video_sense = 0x0
machine.boot "iicx" 8192
rom.reload
scheduler.run 335000000
assert ${screen.width == 1152} "21in_rgb width != 1152"
assert ${screen.height == 870} "21in_rgb height != 870"
assert ${memory.peek.l(0xf920000c) == 0x24} "21in_rgb 1bpp RowWords != 0x24"
screen.match floppy-21in_rgb-1152x870-1bpp.png

quit
