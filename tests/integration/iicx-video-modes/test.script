# Integration test: IIcx Video Modes
#
# Two axes of coverage:
#
# 1. **Depths.** Boot the IIcx with the System 7.0.1 floppy, reach
#    Finder, then drive the Apple Macintosh Display Card 8•24 (JMFB)
#    through 1, 2, 4, and 8 bpp at 640x480 by calling SetDepth on the
#    active GDevice from the running OS.  SetDepth orchestrates
#    cscSetMode + GDevice/gdPMap update + _PaintBehind so the Window
#    Manager redraws the desktop in the new pixel format — the
#    captured Finder-at-N-bpp screenshots reflect what a real user
#    would see after toggling depth in the Monitors control panel.
#    SetDepth is invoked via `screen.set_video_mode N` (see
#    src/core/debug/debug.c — injects a 68k stub at scratch RAM that
#    calls the SetDepth + PaintBehind traps and returns).
#
# 2. **Resolutions.** Cold-boot the IIcx with no boot media, vary
#    `nubus.video_sense` per monitor type (12" RGB / 15" Portrait B&W
#    / 21" RGB Kong), and verify the JMFB driver picks the correct
#    mode-list sRsrc and the framebuffer ends up at the matching
#    pixel dimensions.  Anchored at the boot ROM's "insert disk"
#    floppy/? icon — Mac OS isn't loaded for these because we're
#    testing what the boot ROM + JMFB driver agree on without OS
#    involvement.  See JMFBPrimaryInit.a:78-95 for the sense table
#    and src/core/peripherals/nubus/cards/jmfb.c monitor_for_sense()
#    for the (sense -> width, height) mapping.
#
# Why screen.checksum + assert instead of screen.match for >1bpp:
#   screen.match is hard-coded to 1bpp in debug.c — extending its
#   PNG-load path to compare in RGBA space is more refactor than this
#   test warrants.  screen.checksum is deterministic per (VRAM, format,
#   stride) and gives equivalent regression coverage at non-1bpp
#   depths.  PNG references for 2/4/8bpp are kept alongside for
#   human inspection but aren't byte-compared by the test runner.
#
# SetDepth 32 enters the JMFB's "millions of colours" mode where Mac
# OS writes 4 bytes/pixel (XRGB) into VRAM at stride 2560 and the
# RAMDAC bypass mode scans 3 of those 4 bytes per pixel for display
# (per the Designing Cards & Drivers "24bpp packed-pixel" terminology
# — the storage is XRGB; the visible colour depth is 24).  See
# JMFBDriver.a's TFBM30Parms for the encoding the driver uses.

# === Depth sweep — drive SetDepth from a running Mac OS ===

# Boot to Finder (System 7.0.1 / 8 MB / 13" RGB 640x480 1 bpp).
# Same budget as tests/integration/iicx-floppy.
scheduler.run 250000000

assert ${machine.id == "iicx"} "machine.id != iicx"
assert ${screen.width == 640}  "screen.width != 640"
assert ${screen.height == 480} "screen.height != 480"

# === 1 bpp baseline — Finder at default depth ===
screen.match finder-13in_rgb-640x480-1bpp.png

# === SetDepth 2 ===
screen.set_video_mode 2
scheduler.run 200000000
assert ${memory.peek.l(0xf9200208) == 0x88} "CLUTPBCR after SetDepth 2 != 0x88"
assert ${memory.peek.l(0xf920000c) == 0x28} "RowWords after SetDepth 2 != 0x28"
assert ${screen.checksum() == 309742193}     "screen.checksum at 2bpp Finder mismatch"

# === SetDepth 4 ===
screen.set_video_mode 4
scheduler.run 200000000
assert ${memory.peek.l(0xf9200208) == 0x90} "CLUTPBCR after SetDepth 4 != 0x90"
assert ${memory.peek.l(0xf920000c) == 0x50} "RowWords after SetDepth 4 != 0x50"
assert ${screen.checksum() == -442908457}   "screen.checksum at 4bpp Finder mismatch"

# === SetDepth 8 ===
screen.set_video_mode 8
scheduler.run 200000000
assert ${memory.peek.l(0xf9200208) == 0x98} "CLUTPBCR after SetDepth 8 != 0x98"
assert ${memory.peek.l(0xf920000c) == 0xa0} "RowWords after SetDepth 8 != 0xa0"
assert ${screen.checksum() == 149101200}    "screen.checksum at 8bpp Finder mismatch"

# === SetDepth 32 ("millions of colours" — JMFB stores XRGB, RAMDAC scans 24bpp) ===
screen.set_video_mode 32
scheduler.run 200000000
assert ${memory.peek.l(0xf9200208) == 0x9a} "CLUTPBCR after SetDepth 32 != 0x9a"
assert ${memory.peek.l(0xf920000c) == 0xf0} "RowWords after SetDepth 32 != 0xf0"
assert ${screen.checksum() == 1026734418}   "screen.checksum at 24bpp Finder mismatch"

# === Resolution sweep — cold-boot per monitor sense ===
# Anchor at the boot ROM "insert disk" floppy/? icon at each
# resolution; Mac OS isn't relevant here because the JMFB driver's
# resolution choice is fixed by the sense lines at PrimaryInit time.
# Per-resolution boot uses the same 335 M cycle budget as
# tests/integration/iicx-boot.

# === 12" RGB / Rubik (sense 0x2) — 512x384 ===
nubus.video_sense = 0x2
machine.boot "iicx" 8192
rom.reload
scheduler.run 335000000
assert ${screen.width == 512}  "12in_rgb width != 512"
assert ${screen.height == 384} "12in_rgb height != 384"
assert ${memory.peek.l(0xf920000c) == 0x10} "12in_rgb 1bpp RowWords != 0x10"
screen.match floppy-12in_rgb-512x384-1bpp.png

# === 15" Portrait B&W (sense 0x1) — 640x870 ===
nubus.video_sense = 0x1
machine.boot "iicx" 8192
rom.reload
scheduler.run 335000000
assert ${screen.width == 640}  "15in_bw width != 640"
assert ${screen.height == 870} "15in_bw height != 870"
assert ${memory.peek.l(0xf920000c) == 0x14} "15in_bw 1bpp RowWords != 0x14"
screen.match floppy-15in_bw-640x870-1bpp.png

# === 21" RGB / Kong (sense 0x0) — 1152x870 ===
nubus.video_sense = 0x0
machine.boot "iicx" 8192
rom.reload
scheduler.run 335000000
assert ${screen.width == 1152} "21in_rgb width != 1152"
assert ${screen.height == 870} "21in_rgb height != 870"
assert ${memory.peek.l(0xf920000c) == 0x24} "21in_rgb 1bpp RowWords != 0x24"
screen.match floppy-21in_rgb-1152x870-1bpp.png

quit
