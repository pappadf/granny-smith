# Integration test: IIcx Video Modes
#
# Cold-boot matrix covering 4 monitor types × 4 colour depths on the
# Apple Macintosh Display Card 8•24 (JMFB).  Each combination is a
# separate `machine.boot` of the IIcx with the System 7.0.1 floppy at
# the chosen `nubus.video_sense`, with PRAM seeded so the Slot
# Manager's GET_SLOT_DEPTH (boot ROM $40800820 → $408009F6) picks up
# the desired sResource at boot time.  Mac OS draws the "Welcome to
# Macintosh" splash into the JMFB framebuffer at the seeded depth,
# and the test verifies the rendered framebuffer against a checked-in
# reference PNG.  (Matching at Welcome rather than Finder cuts each
# boot's wall time roughly in half — the JMFB is fully configured by
# the time Welcome paints, so the splash exercises the same depth /
# stride / CLUT plumbing as a Finder match would.)
#
# Boot-to-Welcome budget = 62.5M cycles (50M before the wait routine
# is entered + a 1.5M settle gap around a $017A modifier-key poke that
# short-circuits the Universal-ROM boot-drive-discovery wait + 11M to
# land inside the ~7M-wide stable Welcome window).  See the comment
# at the first `memory.poke.w 0x017A 0x8805` below for the mechanics.
#
# Seeded slot-9 sPRAMRec (8 bytes packed as one big-endian literal):
#
#   $46..$47 = $0027              BoardID = JMFB
#   $48      = spDepth (varies)   savedMode  = $80/$81/$82/$83
#   $49..$4A = sister / sister    savedSRsrcID, savedRawSRsrcID
#                                 (the ACTIVE Ax sister for this sense
#                                  per Apple-341-0868-vrom.asm §6b)
#   $4B..$4D = 00 00 00           specialFlag / clock / pad
#
# `rtc.pram.validate` stamps the two boot-ROM validity tokens
# ($00=$A8 + $0C-$0F='NuMc') so `_InitUtil` skips its cold-init pass;
# without those tokens the seeded slot-PRAM gets clobbered (see
# docs/pram.md §3).
#
# (sense → sister sRsrcID) mapping derived empirically — see Section
# 6b of the JMFB VROM disasm for the full catalog.  PrimaryInit picks
# the Ax sister at boot time; SecondaryInit would upgrade to Bx if
# 32-bit QuickDraw were in ROM, but System 7.0.1 leaves us on Ax:
#
#   sense $0  21" Color Kong / Mac Two-Page    $A7   1152×870
#   sense $1  Mac Portrait Display (B&W)        $A1    640×870
#   sense $2  Mac 12" RGB / small RGB           $A2    512×384
#   sense $6  Mac Hi-Res 13" RGB                $A6    640×480
#
# spDepth $80/$81/$82/$83 = 1/2/4/8 bpp on every Bx/Ax sister.
#
# 24/32 bpp is intentionally NOT covered: on the JMFB, 32bpp lives
# only in spDepth4 of the Ax INACTIVE-pair sisters (e.g. $A6 spDepth4)
# and `_SlotManager $06 sReadFHeader` rejects them at boot — Apple's
# "Millions of Colors" mode was runtime-only on this card and never
# persisted across a reboot.
#
# Reference-image note (Kong yellow tint).  The 21" Color reference
# PNGs at $\geq$2 bpp show a subtle yellow tint compared to the
# perceptually-neutral 13"/12" RGB images.  This is real Apple
# firmware behavior, not an emulation bug: the JMFB driver applies
# a per-monitor gamma table at CLUT-write time (see disasm
# $40FF7E06 + ProgramCLUT at $40FF75BC) that pre-distorts RGB values
# to compensate for each CRT's physical response curve.  On real
# hardware the CRT phosphors apply the inverse and the user sees
# neutral.  Our headless `screen.save` emits the post-driver,
# pre-CRT-response RGB ("what the JMFB put on the bus"), so Kong's
# pre-distortion shows through.  That makes the references
# byte-stable for regression testing but not directly representative
# of the user-facing image; the WebGL frontend applies a per-monitor
# response LUT in the fragment shader, which is the correct place
# for that compensation.

# === Depth × Resolution matrix — one cold boot per (sense, depth) =============
#
# Each iteration uses the same five-line boot prefix:
#
#   scheduler.run 50000000         # past Universal-ROM wait-routine entry
#   memory.poke.w 0x017A 0x8805    # synthesise Cmd-Shift-Power in $017A
#                                  # (KeyMap mods) — short-circuits the
#                                  # boot-drive-discovery wait at $40801610
#                                  # which would otherwise burn ~16.8 s of
#                                  # guest time before failing through to
#                                  # the real boot.
#   scheduler.run 1500000          # one inner 15-tick poll picks up $8805
#                                  # and the wait routine returns via the
#                                  # programmer's-key branch
#   memory.poke.w 0x017A 0         # clear the modifier so System 7's INIT
#                                  # loader doesn't see Cmd held (which
#                                  # would pop a "rebuild desktop?" dialog)
#   scheduler.run 11000000         # land in the Welcome splash stable window

# --- 13" RGB (sense $6) at 1/2/4/8 bpp ---
nubus.video_sense = 0x6
machine.boot "iicx" 8192
rom.reload
floppy.drives[0].insert "../../data/systems/System_7_0_1.image"
rtc.pram.validate
rtc.pram.poke 0x46 0x002780a6a6000000:8
scheduler.run 50000000
memory.poke.w 0x017A 0x8805
scheduler.run 1500000
memory.poke.w 0x017A 0
scheduler.run 11000000
assert ${machine.id == "iicx"}              "machine.id != iicx"
assert ${screen.width == 640}               "13in_rgb 1bpp width != 640"
assert ${screen.height == 480}              "13in_rgb 1bpp height != 480"
assert ${rtc.pram.peek(0x48) == 0x80}       "13in_rgb 1bpp savedMode rewritten by ROM"
assert ${memory.peek.l(0xf9200208) == 0x80} "13in_rgb 1bpp CLUTPBCR != 0x80"
assert ${memory.peek.l(0xf920000c) == 0x14} "13in_rgb 1bpp RowWords != 0x14"
screen.match welcome-13in_rgb-640x480-1bpp.png

nubus.video_sense = 0x6
machine.boot "iicx" 8192
rom.reload
floppy.drives[0].insert "../../data/systems/System_7_0_1.image"
rtc.pram.validate
rtc.pram.poke 0x46 0x002781a6a6000000:8
scheduler.run 50000000
memory.poke.w 0x017A 0x8805
scheduler.run 1500000
memory.poke.w 0x017A 0
scheduler.run 11000000
assert ${rtc.pram.peek(0x48) == 0x81}       "13in_rgb 2bpp savedMode rewritten by ROM"
assert ${memory.peek.l(0xf9200208) == 0x88} "13in_rgb 2bpp CLUTPBCR != 0x88"
assert ${memory.peek.l(0xf920000c) == 0x28} "13in_rgb 2bpp RowWords != 0x28"
screen.match welcome-13in_rgb-640x480-2bpp.png

nubus.video_sense = 0x6
machine.boot "iicx" 8192
rom.reload
floppy.drives[0].insert "../../data/systems/System_7_0_1.image"
rtc.pram.validate
rtc.pram.poke 0x46 0x002782a6a6000000:8
scheduler.run 50000000
memory.poke.w 0x017A 0x8805
scheduler.run 1500000
memory.poke.w 0x017A 0
scheduler.run 11000000
assert ${rtc.pram.peek(0x48) == 0x82}       "13in_rgb 4bpp savedMode rewritten by ROM"
assert ${memory.peek.l(0xf9200208) == 0x90} "13in_rgb 4bpp CLUTPBCR != 0x90"
assert ${memory.peek.l(0xf920000c) == 0x50} "13in_rgb 4bpp RowWords != 0x50"
screen.match welcome-13in_rgb-640x480-4bpp.png

nubus.video_sense = 0x6
machine.boot "iicx" 8192
rom.reload
floppy.drives[0].insert "../../data/systems/System_7_0_1.image"
rtc.pram.validate
rtc.pram.poke 0x46 0x002783a6a6000000:8
scheduler.run 50000000
memory.poke.w 0x017A 0x8805
scheduler.run 1500000
memory.poke.w 0x017A 0
scheduler.run 11000000
assert ${rtc.pram.peek(0x48) == 0x83}       "13in_rgb 8bpp savedMode rewritten by ROM"
assert ${memory.peek.l(0xf9200208) == 0x98} "13in_rgb 8bpp CLUTPBCR != 0x98"
assert ${memory.peek.l(0xf920000c) == 0xa0} "13in_rgb 8bpp RowWords != 0xa0"
screen.match welcome-13in_rgb-640x480-8bpp.png

