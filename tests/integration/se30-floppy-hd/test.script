# Integration test: SE/30 HD Floppy Boot
# Boots SE/30 from a 1.44MB HD MFM floppy disk (System 7.0.1)
# and verifies that the Finder desktop appears.

# Boot to Finder desktop
run 660000000

# Verify the screen matches the Finder desktop reference image
screenshot --match finder.png

# Bring up the "About..." window
set-mouse 25 10
run 2000000
mouse-button down
run 4000000
set-mouse 25 30
run 2000000
mouse-button up
run 45000000

screenshot --match about.png

quit
