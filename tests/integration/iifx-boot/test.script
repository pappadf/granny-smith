# Integration test: IIfx Boot
# Exercises the IIfx-specific ROM, OSS interrupt controller, IOPs, and six-slot NuBus map.

scheduler.run 100000000

assert ${machine.id == "iifx"} "machine.id != iifx"
assert ${rom.checksum == "4147DD77"} "rom.checksum != 4147DD77"

# The default IIfx slot table seats the same JMFB card in slot $9 as IIx.
assert ${screen.width == 640} "screen.width != 640"
assert ${screen.height == 480} "screen.height != 480"
screen.match boot-640x480.png

quit
