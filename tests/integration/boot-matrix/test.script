# Integration test: Boot Matrix
#
# Sequentially cold-boots a Macintosh Plus with four different System
# Software versions, each at a different RAM configuration matching
# what Apple officially supported on a real Plus.  This exercises
# both the boot path for each system version AND every supported
# Plus RAM total (1 / 2 / 2.5 / 4 MB) in one test run.
#
# Real Mac Plus RAM configurations (four 30-pin SIMM slots, two banks):
#   1.0 MB  =  4× 256 KB                (factory default)
#   2.0 MB  =  2× 1 MB + 2 empty
#   2.5 MB  =  2× 1 MB + 2× 256 KB      (asymmetric)
#   4.0 MB  =  4× 1 MB                  (maximum)
#
# Each iteration:
#
#   1. `machine.boot "plus" N`    re-instantiates the Plus at the
#      iteration's RAM size, throwing away all prior guest state.
#   2. `rom.reload`               re-loads the ROM image from disk
#      (the new machine doesn't inherit the prior ROM mapping).
#   3. `floppy.drives[0].insert`  mounts the per-iteration system disk.
#   4. `t0 = ${scheduler.host_user_ns}`  snapshots POSIX user-CPU
#      before this iteration's run.  Typed shell variable — value
#      stored as V_UINT, not coerced to string.
#   5. `scheduler.run N`          per-(system, RAM) instruction budget
#      needed to reach a stable Finder desktop.  Budgets were measured
#      empirically (1M-cycle probe sweep) and rounded up with ~10-14%
#      margin.  Actual first-stable cycles: 15M / 21M / 30M / 36M.
#   6. `screen.match`             verifies against the checked-in
#      reference PNG.  A mismatch is a hard test failure.
#   7. `assert ${scheduler.instr_count * 1e9 / (scheduler.host_user_ns - t0) > FLOOR}`
#      Per-iteration emulator-throughput floor.  scheduler.instr_count
#      is the count for the current machine (machine.boot reset it);
#      the time delta is over just this iteration's scheduler.run.
#      Floor set at 50 MIPS — a comfortable margin below the ~80–100
#      MIPS a modern x86 host delivers at --speed=max.
#
# Note: sub-4 MB RAM configurations depend on the Plus RAM mirror in
# src/machines/plus.c.  The Plus ROM hardcodes its exception save area
# at $3FFC80 (close to the 4 MB ceiling); on a real Plus with less RAM
# the un-decoded address-bus gap [installed_ram, $400000) physically
# wraps that address back into installed RAM.  Without the emulator
# mirror, the first exception at any sub-4-MB size hangs boot at the
# "Welcome to Macintosh" splash.

# --- System Software 2.0 (400K) @ 1 MB RAM --------------------------
machine.boot "plus" 1024
rom.reload
floppy.drives[0].insert "../../data/systems/SSW-2.0-400K/System Disk.image"
t0 = ${scheduler.host_user_ns}
scheduler.run 17000000
assert ${machine.id == "plus"}    "ssw-2.0/1M: machine.id != plus"
assert ${machine.ram == 1024}     "ssw-2.0/1M: machine.ram != 1024"
assert ${screen.width == 512}     "ssw-2.0/1M: screen.width != 512"
assert ${screen.height == 342}    "ssw-2.0/1M: screen.height != 342"
screen.match plus-ssw-2.0.png
echo "ssw-2.0/1M:    ${scheduler.instr_count * 1000 / (scheduler.host_user_ns - t0)} MIPS"
assert ${scheduler.instr_count * 1000000000 / (scheduler.host_user_ns - t0) > 50000000} "ssw-2.0/1M: emulator throughput below 50 MIPS"

# --- System Software 3.2 (400K) @ 2 MB RAM --------------------------
machine.boot "plus" 2048
rom.reload
floppy.drives[0].insert "../../data/systems/SSW-3.2-400K/System Installation v1.0.image"
t0 = ${scheduler.host_user_ns}
scheduler.run 24000000
assert ${machine.id == "plus"}    "ssw-3.2/2M: machine.id != plus"
assert ${machine.ram == 2048}     "ssw-3.2/2M: machine.ram != 2048"
assert ${screen.width == 512}     "ssw-3.2/2M: screen.width != 512"
assert ${screen.height == 342}    "ssw-3.2/2M: screen.height != 342"
screen.match plus-ssw-3.2.png
echo "ssw-3.2/2M:    ${scheduler.instr_count * 1000 / (scheduler.host_user_ns - t0)} MIPS"
assert ${scheduler.instr_count * 1000000000 / (scheduler.host_user_ns - t0) > 50000000} "ssw-3.2/2M: emulator throughput below 50 MIPS"

# --- System Software 4.2 (800K) @ 2.5 MB RAM ------------------------
machine.boot "plus" 2560
rom.reload
floppy.drives[0].insert "../../data/systems/SSW-4.2-800K/System Tools 1.image"
t0 = ${scheduler.host_user_ns}
scheduler.run 33000000
assert ${machine.id == "plus"}    "ssw-4.2/2.5M: machine.id != plus"
assert ${machine.ram == 2560}     "ssw-4.2/2.5M: machine.ram != 2560"
assert ${screen.width == 512}     "ssw-4.2/2.5M: screen.width != 512"
assert ${screen.height == 342}    "ssw-4.2/2.5M: screen.height != 342"
screen.match plus-ssw-4.2.png
echo "ssw-4.2/2.5M:  ${scheduler.instr_count * 1000 / (scheduler.host_user_ns - t0)} MIPS"
assert ${scheduler.instr_count * 1000000000 / (scheduler.host_user_ns - t0) > 50000000} "ssw-4.2/2.5M: emulator throughput below 50 MIPS"

# --- System Software 6.0.8 (800K) @ 4 MB RAM ------------------------
machine.boot "plus" 4096
rom.reload
floppy.drives[0].insert "../../data/systems/SSW-6.08-800K/SSW 6.0.8-800k Disk1of4"
t0 = ${scheduler.host_user_ns}
scheduler.run 40000000
assert ${machine.id == "plus"}    "ssw-6.0.8/4M: machine.id != plus"
assert ${machine.ram == 4096}     "ssw-6.0.8/4M: machine.ram != 4096"
assert ${screen.width == 512}     "ssw-6.0.8/4M: screen.width != 512"
assert ${screen.height == 342}    "ssw-6.0.8/4M: screen.height != 342"
screen.match plus-ssw-6.0.8.png
echo "ssw-6.0.8/4M:  ${scheduler.instr_count * 1000 / (scheduler.host_user_ns - t0)} MIPS"
assert ${scheduler.instr_count * 1000000000 / (scheduler.host_user_ns - t0) > 50000000} "ssw-6.0.8/4M: emulator throughput below 50 MIPS"

# ====================================================================
# SE/30 iterations
# ====================================================================
#
# The SE/30 uses the Universal ROM (the same image shared with IIcx and
# IIx; we keep the canonical filename IIcx.rom).  Switching ROMs is a
# `rom.load` from the script — the daemon was started with Plus_v3.rom
# from config.mk, but each iteration is free to swap ROMs before
# running.  The Universal ROM also runs a ~13 s (guest time) boot-drive-
# discovery wait at $40801610 before falling through to the actual boot;
# we short-circuit it by poking the Cmd-Shift-Power modifier combo into
# the lowmem KeyMap global at $017A, then clearing it after one inner
# poll cycle.  See tests/integration/iicx-video-modes/test.script for
# the full mechanism.

# --- SE/30 + System Software 6.0.8 (800K) @ 4 MB RAM ----------------
machine.boot "se30" 4096
rom.load "../../data/roms/IIcx.rom"
floppy.drives[0].insert "../../data/systems/SSW-6.08-800K/SSW 6.0.8-800k Disk1of4"
t0 = ${scheduler.host_user_ns}
scheduler.run 40000000
memory.poke.w 0x017A 0x8805
scheduler.run 2000000
memory.poke.w 0x017A 0
scheduler.run 33000000
assert ${machine.id == "se30"}    "se30-ssw-6.0.8/4M: machine.id != se30"
assert ${machine.ram == 4096}     "se30-ssw-6.0.8/4M: machine.ram != 4096"
assert ${screen.width == 512}     "se30-ssw-6.0.8/4M: screen.width != 512"
assert ${screen.height == 342}    "se30-ssw-6.0.8/4M: screen.height != 342"
screen.match se30-ssw-6.0.8.png
echo "se30/ssw-6.0.8/4M: ${scheduler.instr_count * 1000 / (scheduler.host_user_ns - t0)} MIPS"
# SE/30 floor is well below Plus's 50 MIPS because the SE/30 *boot* phase
# emulates much more slowly than steady-state.  Measured at the time of
# writing:
#   Plus 4MB,  4M-instr boot         ~ 95 MIPS
#   SE/30 4MB, 75M-instr boot        ~ 13 MIPS   <-- this row
#   SE/30 4MB, 50M-instr steady state ~ 53 MIPS  (after Welcome)
# i.e. the steady-state 68030 cost is ~2× 68000 (reasonable for the
# PMMU/FPU/wider-ISA overhead), but the boot phase is ~8× — likely from
# MMU table init, 4 MB RAM probe, and cold-path memory access overhead.
# This is worth a separate perf investigation; for now the floor catches
# anything that pushes the boot-phase cost below ~80% of the current
# baseline.
assert ${scheduler.instr_count * 1000000000 / (scheduler.host_user_ns - t0) > 10000000} "se30-ssw-6.0.8/4M: emulator throughput below 10 MIPS"

# --- IIcx + System Software 6.0.8 (800K) @ 4 MB RAM, 13" RGB 1bpp ----
# Same Universal ROM and $017A wait-bypass as the SE/30 row above; the
# wrinkle here is the NuBus JMFB (Display Card 8•24), which the IIcx
# uses for video.  We seed `nubus.video_sense=$6` (13" RGB) plus a
# matching slot-9 sPRAMRec so the Slot Manager picks the 640×480 @
# 1bpp sister at boot — see tests/integration/iicx-video-modes for the
# full sense/PRAM mechanism.  After Finder paints we click through the
# Apple menu to "About the Finder" and match the dialog (which carries
# the "Total Memory: 4,096K" line — extra confirmation that ram=4096
# took effect end-to-end).
nubus.video_sense = 0x6
machine.boot "iicx" 4096
rom.load "../../data/roms/IIcx.rom"
floppy.drives[0].insert "../../data/systems/SSW-6.08-800K/SSW 6.0.8-800k Disk1of4"
rtc.pram.validate
rtc.pram.poke 0x46 0x002780a6a6000000:8
t0 = ${scheduler.host_user_ns}
scheduler.run 30000000
memory.poke.w 0x017A 0x8805
scheduler.run 2000000
memory.poke.w 0x017A 0
scheduler.run 33000000
# Bring up "About the Macintosh Finder" via the Apple menu.  Cursor
# default position at boot is already over the Apple icon, so a bare
# `mouse.click true` is enough — no prior `mouse.move` needed.
mouse.click true
scheduler.run 3000000
mouse.move 25 30 "global"
scheduler.run 3000000
mouse.click false
scheduler.run 5000000
assert ${machine.id == "iicx"}    "iicx-ssw-6.0.8/4M: machine.id != iicx"
assert ${machine.ram == 4096}     "iicx-ssw-6.0.8/4M: machine.ram != 4096"
assert ${screen.width == 640}     "iicx-ssw-6.0.8/4M: screen.width != 640"
assert ${screen.height == 480}    "iicx-ssw-6.0.8/4M: screen.height != 480"
screen.match iicx-ssw-6.0.8.png
echo "iicx/ssw-6.0.8/4M: ${scheduler.instr_count * 1000 / (scheduler.host_user_ns - t0)} MIPS"
# Floor is well below the SE/30 row because this iteration runs only ~60 M
# instructions to Finder-plus-About; the formula divides by *iteration*
# host time, so a budget dominated by the (slow) cold-boot phase pulls
# the effective MIPS down — current baseline ~8 MIPS.
assert ${scheduler.instr_count * 1000000000 / (scheduler.host_user_ns - t0) > 5000000} "iicx-ssw-6.0.8/4M: emulator throughput below 5 MIPS"

# --- IIcx + SSW 7.0 "Disk Tools" (800K) @ 8 MB RAM, 13" RGB 2bpp -----
# The SSW 7.0 Disk Tools floppy ships its boot blocks as System 6.0.7 +
# Finder 6.1.7 (the actual System 7 install set doesn't fit on an 800K
# disk), so this row visually resembles the SSW 6.0.8 row above — the
# coverage it adds is on the *configuration* axes: 8 MB RAM and a 2bpp
# JMFB mode ($81 savedMode + $A6 sister for 13" RGB at 640×480).  The
# About box reports "Total Memory: 8,192K" — extra confirmation that
# ram=8192 took effect.  Cycle budgets are wider than the 6.0.8 row
# because Disk Tools' INIT chain is heavier.
nubus.video_sense = 0x6
machine.boot "iicx" 8192
rom.load "../../data/roms/IIcx.rom"
floppy.drives[0].insert "../../data/systems/SSW-7.0-800K/Disk Tools.image"
rtc.pram.validate
rtc.pram.poke 0x46 0x002781a6a6000000:8
t0 = ${scheduler.host_user_ns}
scheduler.run 30000000
memory.poke.w 0x017A 0x8805
scheduler.run 2000000
memory.poke.w 0x017A 0
scheduler.run 35000000
mouse.click true
scheduler.run 3000000
mouse.move 25 30 "global"
scheduler.run 3000000
mouse.click false
scheduler.run 5000000
assert ${machine.id == "iicx"}    "iicx-ssw-7.0/8M: machine.id != iicx"
assert ${machine.ram == 8192}     "iicx-ssw-7.0/8M: machine.ram != 8192"
assert ${screen.width == 640}     "iicx-ssw-7.0/8M: screen.width != 640"
assert ${screen.height == 480}    "iicx-ssw-7.0/8M: screen.height != 480"
screen.match iicx-ssw-7.0.png
echo "iicx/ssw-7.0/8M: ${scheduler.instr_count * 1000 / (scheduler.host_user_ns - t0)} MIPS"
assert ${scheduler.instr_count * 1000000000 / (scheduler.host_user_ns - t0) > 5000000} "iicx-ssw-7.0/8M: emulator throughput below 5 MIPS"

quit
