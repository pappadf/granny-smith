# Integration test: IIcx Keyboard — System 7.1 Find dialog
#
# Regression guard for the ADB keyboard "drops most keystrokes" bug on a IIcx
# booted from the System 7.1 (1.4 MB) "Disk Tools" floppy.  The test:
#
#   1. Cold-boots the IIcx from "Disk Tools.img" to the Finder desktop.
#   2. Drives File > Find...  ENTIRELY with the mouse — pulling down the
#      File menu, highlighting "Find...", and releasing on it.  The Find
#      dialog opening at all is proof the ADB *mouse* path is healthy
#      (matches `find-dialog.png`).
#   3. Types the 9-letter word "macintosh" into the (auto-focused) Find
#      text field via the ADB *keyboard* path and asserts the field reads
#      exactly "macintosh" (matches `typed-macintosh.png`).
#
# ---------------------------------------------------------------------------
# The bug this guards against (fixed 2026-06-26, src/core/peripherals/adb.c):
#
#   The IIcx ADB keyboard dropped roughly every other keystroke under System
#   7.1.  Typing m-a-c-i-n-t-o-s-h produced "aits" — only the 2nd/4th/6th/8th
#   keys survived.  Root cause: when the Universal ROM probes the keyboard
#   during its SRQ scan it issues a Talk R0 that prepare_kbd_reply serviced by
#   *destructively dequeuing* up to two key bytes, then aborted the Talk
#   (CMD->IDLE) without ever fetching them.  The aborted-Talk recovery only
#   re-marked MOUSE data as pending, so the dequeued keyboard bytes were lost,
#   and the spurious mouse re-mark forced the next key back through the same
#   SRQ-scan path — hence the strict alternation.  Fix: on an aborted keyboard
#   Talk, restore the queue tail so the un-fetched key transitions are
#   re-presented on the next poll (real ADB keyboards retain unread data).
#
# If this match fails with the field showing fewer/garbled characters, that
# regression is back.  Diagnose with `debug.log "adb" 2` while typing and look
# for "aborted kbd Talk" followed by the dropped bytes never being re-presented.
# ---------------------------------------------------------------------------
#
# keyboard.press note: the shell key resolver (debug_mac_resolve_key_name)
# only accepts named special keys (return/space/esc/tab/delete/arrows/cmd/
# shift/option/ctrl) or a hex ADB virtual keycode.  Letters are NOT names, so
# "macintosh" is spelled out as ADB scancodes below
# (m=0x2E a=0x00 c=0x08 i=0x22 n=0x2D t=0x11 o=0x1F s=0x01 h=0x04).
#
# Video: seed nubus.video_sense=$6 (13" RGB) + a matching slot-9 sPRAMRec so
# the Slot Manager picks 640x480 @ 2bpp at boot — same mechanism as the
# boot-matrix IIcx rows and tests/integration/iicx-video-modes.

machine.boot model="iicx" ram=8192 video_sense=6
machine.floppy.drive[0].insert "../../data/systems/SSW-7.1-1.4M/Disk Tools.img"
machine.rtc.pram.validate
machine.rtc.pram.poke 0x46 0x002781a6a6000000:8

# Boot to the Finder desktop.  The poke/clear of $017A mid-boot skips the
# Universal ROM's boot-drive-discovery key-scan at $40801610 — see
# tests/integration/iicx-video-modes/test.script for the mechanics.
scheduler.run 30000000
machine.memory.poke.w 0x017A 0x8805
scheduler.run 2000000
machine.memory.poke.w 0x017A 0
scheduler.run 45000000

assert ${machine.id == "iicx"}  "machine.id != iicx"
assert ${machine.ram == 8192}   "machine.ram != 8192"
assert ${machine.screen.width == 640}   "screen.width != 640 (JMFB not seated?)"
assert ${machine.screen.height == 480}  "screen.height != 480"
machine.screen.match desktop.png

# --- Open File > Find... with the MOUSE (proves the mouse path works) ------
# Pull-down pattern: move onto the "File" title (~x=38) in the menu bar,
# mousedown to draw the menu, move down to "Find..." (y=200, verified by
# highlight), mouseup to fire it.
machine.adb.mouse.move 38 7 "global"
scheduler.run 3000000
machine.adb.mouse.click true
scheduler.run 6000000
machine.adb.mouse.move 38 200 "global"
scheduler.run 4000000
machine.adb.mouse.click false
scheduler.run 30000000
machine.screen.match find-dialog.png

# --- Type "macintosh" into the (auto-focused) Find field -------------------
# Back-to-back presses, mirroring the keyboard.press cadence sibling tests
# use (e.g. se30-aux3-boot typing "root").  All nine keys must land.
machine.adb.keyboard.press 0x2E
machine.adb.keyboard.press 0x00
machine.adb.keyboard.press 0x08
machine.adb.keyboard.press 0x22
machine.adb.keyboard.press 0x2D
machine.adb.keyboard.press 0x11
machine.adb.keyboard.press 0x1F
machine.adb.keyboard.press 0x01
machine.adb.keyboard.press 0x04
scheduler.run 60000000

# Save the actual result as an artifact, then assert the field reads exactly
# "macintosh".  See the bug note above — a mismatch with fewer characters
# means the every-other-key drop has regressed.
machine.screen.save "${WORK_DIR}/typed-macintosh.png"
machine.screen.match typed-macintosh.png

quit
