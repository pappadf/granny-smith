# Integration test: Shell Commands
# Exercises v2 command framework with GDB-style naming.

# Run a few instructions to initialize state
run 100

# Test: info regs shows register dump (replaces td)
info regs

# Test: info r alias works
info r

# Test: disasm defaults to PC when no address given
disasm

# Test: disasm with count only (alias 'd')
d 5

# Test: help for specific command (v2 name)
help info

# Test: info fpregs (replaces fpregs command)
info fpregs

# Test: prompt off suppresses status line
prompt off

# Test: prompt on re-enables it
prompt on

# Test: logpoint list (should be empty)
logpoint list

# Test: info mac (replaces mac-state)
info mac

quit
