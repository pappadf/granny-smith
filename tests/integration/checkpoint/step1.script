# Step 1: Boot from floppy and save checkpoint
# Run 50M instructions to get partway through boot process

scheduler.run 50000000

# Save machine state to checkpoint file. assert fails the step if the
# typed wrapper returned false (silent failure used to be masked by
# path-form returning 0 regardless of the bool result).
assert ${checkpoint.save("checkpoint")} "step1 checkpoint save failed"

quit
