# Integration test: IIfx MacTest Boot (8-bit colour)
# Boots the Macintosh IIfx from the MacTest 1.0 floppy with the JMFB display
# card configured for 13" RGB at 8 bpp, and verifies MacTest's launch-time
# hardware-identification panel renders correctly in 256-colour mode.
#
# This depth is a regression guard for a 24-bit-addressing bug: System 6.0.5
# runs the IIfx in 24-bit mode, where Memory Manager master pointers carry
# lock/purge/resource flags in their high byte.  Under 8 bpp memory pressure
# the Font Manager's synthetic strikes become purgeable, so their master
# pointers acquire the $40 purge flag (logical $40xxxxxx for a block at
# physical $00xxxxxx).  The emulator must let the 24-bit MMU tree (TC.IS=8)
# strip that flag rather than dispatch the static $40xxxxxx ROM page — see
# dispatch_device_at_logical() in src/core/memory/memory.c.  Before the fix
# the dereference returned ROM garbage, the Font Manager overran its width
# table, and the Memory Manager's free-block walk hung.
#
# Companion tests:
#   - tests/integration/iifx-boot     boots the same IIfx ROM to the
#                                     System 7.0.1 Finder desktop.
#   - tests/integration/iicx-mactest  drives the IIcx/IIci MacTest suite.
#   - tests/integration/iicx-video-modes  cold-boot depth/resolution matrix.

# Configure the JMFB for 13" RGB at 8 bpp before boot (same mechanism as
# iicx-mactest); the pending mode is applied by the following machine.boot.
machine.nubus.video_mode = "13in_rgb_8bpp"
machine.boot "iifx" 16384
machine.rom.reload
machine.floppy.drives[0].insert "../../data/apps/MacTest-IIfx.image" true

# Boot to the Happy Mac, run MacTest's launch-time hardware probe, and draw
# the main window.  At 8 bpp the window is painted and stable by ~340M
# instructions; 360M gives a comfortable margin.  This must match the cycle
# count main.png was captured at for the screen.match below to be deterministic.
scheduler.run 360000000

assert ${machine.id == "iifx"}              "machine.id != iifx"
assert ${machine.rom.checksum == "4147DD77"}        "rom.checksum != 4147DD77"

# JMFB seated for 13" RGB 8 bpp: 640x480, savedMode $83, and the slot-9 JMFB
# CLUTPBCR / RowWords registers match the iicx-video-modes 8 bpp baseline.
assert ${machine.screen.width == 640}               "screen.width != 640"
assert ${machine.screen.height == 480}              "screen.height != 480"
assert ${machine.rtc.pram.peek(0x48) == 0x83}       "savedMode != 0x83 (8bpp)"
assert ${machine.memory.peek.l(0xf9200208) == 0x98} "JMFB CLUTPBCR != 0x98 (8bpp)"
assert ${machine.memory.peek.l(0xf920000c) == 0xa0} "JMFB RowWords != 0xa0 (640*8/8/8)"

# Verify the MacTest main window matches the reference: MacTest menu bar, the
# Start/Stop/Pause/Log toolbar, and the hardware-identification panel reporting
# System type "Macintosh IIfx", CPU 68030, FPU 68882, ROM size 512 KB, RAM
# size 16 MB, rendered in 256 colours.
machine.screen.match main.png

quit
