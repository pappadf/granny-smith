# Cold-boot LOS from the installed ProFile hard disk (no floppy), relying on the
# image's OWN on-disk PRAM snapshot.  See config.mk + docs/machines/lisa/pram_format.md.
#
# The ProFile image is the one the lisa-los-profile install test produces (copied
# to a writable scratch path by TEST_SETUP).  The PRAM (also from TEST_SETUP, via
# `seed_pram.py --coldboot`) is intentionally invalid: BootVol=2 so the ROM boots
# the ProFile, but an empty device table + corrupted checksum so the OS computes
# pm_good=false and restores the device configuration from the boot volume's MDDF
# snapshot (the copy written at a clean shutdown FROM the ProFile).  A good image
# resolves the ProFile from that snapshot and boots; a non-clean-shutdown image
# leaves a floppy-only snapshot and fails with error 10738.

machine.hd.attach "$WORK_DIR/profile.image"
assert machine.id == "lisa" "machine.id != lisa"
assert machine.rom.checksum == "098917B2" "rom.checksum != 098917B2 (rev-H)"
assert machine.hd.present == true "ProFile should be attached"

# Seed (invalid) parameter memory before the ROM reads it at startup.
assert machine.hd.pram_load("${$WORK_DIR}/profile.pram") "pram_load failed"

# The ROM reads PRAM -> BootVol=2 -> PROBOOT the ProFile -> loader -> SYSTEM.OS;
# pm_good=false, so INIT_CONFIG restores the on-disk MDDF snapshot and FIND_PM_IDS
# resolves the ProFile (cd_paraport) from it.  By ~100M instructions LOS has booted
# to the Office System desktop, which opens a first-boot "Lisa clock/calendar is not
# set properly" note (the emulated COPS real-time clock reads zero, so the OS offers
# to set it).
scheduler.run 100000000

# Dismiss the note: warp the cursor onto its OK button (closed-loop on the OS cursor
# globals $CC00F0/F2 — live on this modal) and click, leaving the clean Office System
# desktop: the menu bar (Desk / File-Print / Edit / Housekeeping) with the
# Preferences / Wastebasket / Clipboard / Disk icons.
machine.adb.mouse.move 622 108 "global"
scheduler.run 2000000
machine.adb.mouse.click true
scheduler.run 600000
machine.adb.mouse.click false
scheduler.run 12000000
machine.screen.match expected.png
quit
