# Integration test: Phase 3 image-VFS descent into A/UX UFS.
# Runner cd's into this directory; paths are relative.

# Partition 6 is "UNIX Root&Usr slice 0" — the A/UX root filesystem.
image partmap ../../data/aux/aux_3.0.1/APPLE_AUX_3-0-1_RETAIL.iso

# Descend into the mount: should list partition1..7.
ls ../../data/aux/aux_3.0.1/APPLE_AUX_3-0-1_RETAIL.iso

# UFS root directory — A/UX 3.0 layout includes bin, etc, usr, dev, mac, ...
ls ../../data/aux/aux_3.0.1/APPLE_AUX_3-0-1_RETAIL.iso/partition6

# One level deeper — /etc has well-known files (motd, passwd, ...).
ls ../../data/aux/aux_3.0.1/APPLE_AUX_3-0-1_RETAIL.iso/partition6/etc

# Exercise file reads end to end: small text file + size check.
cat ../../data/aux/aux_3.0.1/APPLE_AUX_3-0-1_RETAIL.iso/partition6/etc/motd
exists ../../data/aux/aux_3.0.1/APPLE_AUX_3-0-1_RETAIL.iso/partition6/etc/passwd
exists ../../data/aux/aux_3.0.1/APPLE_AUX_3-0-1_RETAIL.iso/partition6/unix

# Writes into a UFS image path must be structurally refused (EROFS).
mkdir ../../data/aux/aux_3.0.1/APPLE_AUX_3-0-1_RETAIL.iso/partition6/newdir

# Recursive cp out of UFS into WORK_DIR (host path provided by runner).
# /etc is ~380 entries including symlinks; exercises direct + single-indirect
# reads, symlink extraction (via file contents), and mkdir recursion.
cp -r ../../data/aux/aux_3.0.1/APPLE_AUX_3-0-1_RETAIL.iso/partition6/etc ${WORK_DIR}/aux-etc
ls ${WORK_DIR}/aux-etc

# Auto-mount cache visible to the user.
image list

# Force-unmount releases the cache entry.
image unmount ../../data/aux/aux_3.0.1/APPLE_AUX_3-0-1_RETAIL.iso
image list

quit
