# Run a few thousand instructions so PC has actually moved.
run 50000

# Object-model resolver smoke checks. The output must contain the
# expected JSON-like shape for each path. (The harness greps stdout
# downstream of these lines.)
eval machine.model_id
eval machine.model_name
eval machine.cpu_clock_hz
eval cpu.pc
eval cpu.d0
eval cpu.a7
eval memory.ram_size
eval memory.rom_size

# Bare object reads return a {"object":...} record.
eval cpu
eval scheduler

# Unknown paths fail cleanly with an error JSON.
eval ghost.path

# M3 paths — the new mac class is auto-populated from
# mac_globals_data.c, so these resolve as V_UINT (size 1/2/4) or
# V_BYTES (other sizes). Parity vs. the legacy `$NAME` resolver is
# covered by the existing shell-commands integration tests (which
# still exercise `$pc` etc. via `info regs`) plus the alias unit
# suite — the alias table now backs both paths.
eval mac.MBState
eval mac.Ticks
eval mac.ROMBase
eval cpu.ccr
eval cpu.sp

quit
