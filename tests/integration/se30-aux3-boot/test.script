# SE/30 A/UX 3.0.1 HD Boot.
#
# Boots the SE/30 from a pre-installed A/UX 3.0.1 HD image and runs long
# enough to clear the early kernel boot phase.

# Pin the wall clock so screenshot comparisons are reproducible. This
# specific seed used to panic with "Sorry, a system error occurred."
# before the se30 slot-deassert fix (commit db03c13). Booting cleanly
# at this seed proves the fix.
rtc.time = 2026-04-26T21:30:36

run 300000000

# enter user "root"
keyboard.press 0x0F
keyboard.press 0x1F
keyboard.press 0x1F
keyboard.press 0x11
keyboard.press return

# enter empty password
keyboard.press return

run 100000000

screen.match desktop.png

# select "CommandShell" via Special menu
mouse.move 20 10 "aux"
run 10000000
mouse.click true
run 10000000
mouse.move 20 110 "aux"
run 10000000
mouse.click false
run 10000000

# The command shell should now be open
screen.match shell.png

# enter command "ls"
keyboard.press 0x25
keyboard.press 0x01
keyboard.press return

run 10000000

# The shell should have run `ls` and printed a directory listing
screen.match ls.png

quit
