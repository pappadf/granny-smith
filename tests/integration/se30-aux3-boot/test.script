# SE/30 A/UX 3.0.1 HD Boot.
#
# Boots the SE/30 from a pre-installed A/UX 3.0.1 HD image, logs in as root,
# opens a CommandShell, and runs `ls` — verifying the full boot-to-shell path.

# Pin the wall clock so screenshot comparisons are reproducible. This
# specific seed used to panic with "Sorry, a system error occurred."
# before the se30 slot-deassert fix (commit db03c13). Booting cleanly
# at this seed proves the fix.
machine.rtc.time = "2026-04-26T21:30:36"

# Skip the Universal ROM's boot-drive-discovery key-scan at $40801610 (poke
# $8805 into $017A, clear it after one inner-poll cycle).  See
# tests/integration/iicx-video-modes/test.script for the mechanics.
scheduler.run 40000000
machine.memory.poke.w 0x017A 0x8805
scheduler.run 2000000
machine.memory.poke.w 0x017A 0

# Boot to the A/UX login window (~692M instructions).  A/UX is interrupt-
# driven: the kernel sleeps for each disk read and is woken by the SCSI DRQ
# "data ready" interrupt, which the NCR 5380 model raises autonomously from
# the scheduler (scsi.c scsi_drq_service) so a STOP-halted kernel resumes.
# Run in chunks so the per-frame VBL heartbeat is injected across the boot.
#
# The first chunk is budget-pinned against an A/UX-internal race in the
# CommandShell launch: at some boot phases the DA installs its menus but
# defers its window until the next keyboard event reaches its pty.  The
# boot-chime producer (sound stage 1: the ASC now really renders the chime,
# adding sample-rate scheduler events during the mode-2 window) shifted the
# phase into the slow arm; 248M re-pinned it to the fast arm with every
# golden unchanged.  If a future timing change trips shell.png again, nudge
# this chunk ±a few M instructions — or, if the interaction still completes,
# regenerate the goldens (see below).
scheduler.run 248000000
scheduler.run 200000000
scheduler.run 200000000

# enter user "root"
machine.adb.keyboard.press 0x0F
machine.adb.keyboard.press 0x1F
machine.adb.keyboard.press 0x1F
machine.adb.keyboard.press 0x11
machine.adb.keyboard.press return

# enter empty password
machine.adb.keyboard.press return

scheduler.run 100000000

machine.screen.match desktop.png

# open the Apple menu and select the CommandShell desk accessory
machine.adb.mouse.move 20 10 "aux"
scheduler.run 15000000
machine.adb.mouse.click true
scheduler.run 15000000
machine.adb.mouse.move 20 110 "aux"
scheduler.run 15000000
machine.adb.mouse.click false
scheduler.run 20000000

# The command shell should now be open.  Goldens regenerated 2026-07-17: the
# fractional-CPI scheduler change fixed a frame-budget wrap on STOP'd-CPU
# tails (the old code could silently run a "frame" on to the next stop event
# with no VBL injection), which shifted the VBL cadence around A/UX idle.
# Under the fixed cadence the CommandShell interaction now completes inside
# the budgets: shell.png shows the opened window with the login banner
# (previously it pinned the Apple menu still open, window deferred), and
# ls.png shows the executed listing.
machine.screen.match shell.png

# enter command "ls"
machine.adb.keyboard.press 0x25
machine.adb.keyboard.press 0x01
machine.adb.keyboard.press return

scheduler.run 20000000

# The shell should have run `ls` and printed a directory listing
machine.screen.match ls.png

quit
