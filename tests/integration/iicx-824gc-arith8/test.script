machine.memory.poke.l 0x9C00778C 0x00643030
machine.memory.poke.l 0x9C007790 0x30303030
machine.memory.poke.l 0x9C007794 0x00000000
machine.memory.poke.l 0x9C007798 0x00050000
machine.memory.poke.l 0x9C00779C 0x00000038
machine.memory.poke.l 0x9C0077A0 0x0002003C
machine.memory.poke.l 0x9C0077A4 0x0064B0B0
machine.memory.poke.l 0x9C0077A8 0xB0B0B0B0
machine.memory.poke.l 0x9C0077AC 0x00000000
machine.memory.poke.l 0x9C0077B0 0x00050000
machine.memory.poke.l 0x9C0077B4 0x00000040
machine.memory.poke.l 0x9C0077B8 0x00020044
machine.memory.poke.l 0x9C0077BC 0x00644040
machine.memory.poke.l 0x9C0077C0 0x40404040
machine.memory.poke.l 0x9C0077C4 0x00000000
machine.memory.poke.l 0x9C0077C8 0x00690020
machine.memory.poke.l 0x9C0077CC 0x00050000
machine.memory.poke.l 0x9C0077D0 0x00000000
machine.memory.poke.l 0x9C0077D4 0x00020004
machine.memory.poke.l 0x9C0077D8 0x00700000
machine.memory.poke.l 0x9C0077DC 0xC0C0C0C0
machine.memory.poke.l 0x9C0077E0 0xC0C00000
machine.memory.poke.l 0x9C0077E4 0x00000000
machine.memory.poke.l 0x9C0077E8 0x00648080
machine.memory.poke.l 0x9C0077EC 0x80808080
machine.memory.poke.l 0x9C0077F0 0x00000000
machine.memory.poke.l 0x9C0077F4 0x00690021
machine.memory.poke.l 0x9C0077F8 0x00050000
machine.memory.poke.l 0x9C0077FC 0x00000008
machine.memory.poke.l 0x9C007800 0x0002000C
machine.memory.poke.l 0x9C007804 0x00690022
machine.memory.poke.l 0x9C007808 0x00050000
machine.memory.poke.l 0x9C00780C 0x00000010
machine.memory.poke.l 0x9C007810 0x00020014
machine.memory.poke.l 0x9C007814 0x00700000
machine.memory.poke.l 0x9C007818 0x20202020
machine.memory.poke.l 0x9C00781C 0x20200000
machine.memory.poke.l 0x9C007820 0x00000000
machine.memory.poke.l 0x9C007824 0x00690023
machine.memory.poke.l 0x9C007828 0x00050000
