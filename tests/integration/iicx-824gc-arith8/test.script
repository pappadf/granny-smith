machine.memory.poke.l 0x9C007830 0x0002001C
machine.memory.poke.l 0x9C007834 0x00649090
machine.memory.poke.l 0x9C007838 0x90909090
machine.memory.poke.l 0x9C00783C 0x00000000
machine.memory.poke.l 0x9C007840 0x00690024
machine.memory.poke.l 0x9C007844 0x00050000
machine.memory.poke.l 0x9C007848 0x00000020
machine.memory.poke.l 0x9C00784C 0x00020024
machine.memory.poke.l 0x9C007850 0x0064FFFF
machine.memory.poke.l 0x9C007854 0xFFFFFFFF
machine.memory.poke.l 0x9C007858 0x00000000
machine.memory.poke.l 0x9C00785C 0x00050000
machine.memory.poke.l 0x9C007860 0x00000028
machine.memory.poke.l 0x9C007864 0x0002002C
machine.memory.poke.l 0x9C007868 0x00648080
machine.memory.poke.l 0x9C00786C 0x80808080
machine.memory.poke.l 0x9C007870 0x00000000
machine.memory.poke.l 0x9C007874 0x00690025
machine.memory.poke.l 0x9C007878 0x00050000
machine.memory.poke.l 0x9C00787C 0x00000030
machine.memory.poke.l 0x9C007880 0x00020034
machine.memory.poke.l 0x9C007884 0x00690026
machine.memory.poke.l 0x9C007888 0x00050000
machine.memory.poke.l 0x9C00788C 0x00000038
machine.memory.poke.l 0x9C007890 0x0002003C
machine.memory.poke.l 0x9C007894 0x00690027
machine.memory.poke.l 0x9C007898 0x00050000
machine.memory.poke.l 0x9C00789C 0x00000040
machine.memory.poke.l 0x9C0078A0 0x00020044
machine.memory.poke.l 0x9C0078A4 0x00690008
machine.memory.poke.l 0x9C0078A8 0x00740000
machine.memory.poke.l 0x9C0078AC 0x00018000
machine.memory.poke.l 0x9C0078B0 0x80008000
machine.memory.poke.l 0x9C0078B4 0x00050000
machine.memory.poke.l 0x9C0078B8 0x00000048
machine.memory.poke.l 0x9C0078BC 0x0002004C
machine.memory.poke.l 0x9C0071C0 0x000001EC
assert ${machine.nubus.slot[9].card.gc.queue_bytes == 0x1EC}      "queue not drained"

assert ${machine.memory.peek.b(0x9C011400) == 0x60}       "blend $20: (4040*7FFF + 8080*8001)>>16 = 6060"
assert ${machine.memory.peek.b(0x9C011408) == 0xC0}       "addPin $21: 8080+6060 = E0E0 > pin C0C0 -> pin"
assert ${machine.memory.peek.b(0x9C011410) == 0x41}       "addOver $22: 8080+C0C0 wraps to 4140"
assert ${machine.memory.peek.b(0x9C011418) == 0x20}       "subPin $23: 6060-8080 borrows -> pin 2020"
assert ${machine.memory.peek.b(0x9C011420) == 0x90}       "transparent $24: src 90 != transColor -> copy"
assert ${machine.memory.peek.b(0x9C011428) == 0x30}       "transparent $24: src == transColor (white) -> untouched"
assert ${machine.memory.peek.b(0x9C011430) == 0x80}       "adMax $25: max(8080, 3030)"
assert ${machine.memory.peek.b(0x9C011438) == 0xAF}       "subOver $26: 3030-8080 wraps to AFB0 -> AF"
assert ${machine.memory.peek.b(0x9C011440) == 0x80}       "adMin $27: min(8080, B0B0)"

# RGBPat: row 0 = cells 0/1 alternating (AA,55), row 1 = cells 2/3 (55,AA).
assert ${machine.memory.peek.l(0x9C011448) == 0xAA55AA55}  "RGBPat row 0 != aa55aa55"
assert ${machine.memory.peek.l(0x9C011848) == 0x55AA55AA}  "RGBPat row 1 != 55aa55aa"

# --- func $0C CachePixPat: synthetic PixPat records in guest RAM ($400000 —
#     low RAM is still ROM-overlaid at power-on).  PixMap: rowBytes 2,
#     bounds (0,0,4,8), pixelSize 2.  patData: every row = 2-bpp indexes
#     0,1,2,3,0,1,2,3 ($1B $1B).  ColorTable: ctSize 3, value k -> grey
#     $20+$20k (ramp indexes $20/$40/$60/$80). ---
machine.memory.poke.l 0x00400000 0x00000000
machine.memory.poke.l 0x00400004 0x00020000
machine.memory.poke.l 0x00400008 0x00000004
machine.memory.poke.l 0x0040000C 0x00080000
machine.memory.poke.l 0x00400020 0x00020000
machine.memory.poke.l 0x00400040 0x1B1B1B1B
machine.memory.poke.l 0x00400044 0x1B1B1B1B
machine.memory.poke.l 0x00400080 0x00000000
machine.memory.poke.l 0x00400084 0x00000003
machine.memory.poke.l 0x00400088 0x00002020
machine.memory.poke.l 0x0040008C 0x20202020
machine.memory.poke.l 0x00400090 0x00014040
machine.memory.poke.l 0x00400094 0x40404040
machine.memory.poke.l 0x00400098 0x00026060
machine.memory.poke.l 0x0040009C 0x60606060
machine.memory.poke.l 0x004000A0 0x00038080
machine.memory.poke.l 0x004000A4 0x80808080
# Arg block (6 longs at the args area CB+$64C): {key, patType 1, &PixMap,
# &patData, &ColorTable, ctSize}; then the func $0C doorbell (seq 2).
machine.memory.poke.l 0x9C00764C 0xDEAD0001
machine.memory.poke.l 0x9C007650 0x00000001
machine.memory.poke.l 0x9C007654 0x00400000
machine.memory.poke.l 0x9C007658 0x00400040
machine.memory.poke.l 0x9C00765C 0x00400080
machine.memory.poke.l 0x9C007660 0x00000003
machine.memory.poke.l 0x9C007048 0x0000000C
machine.memory.poke.l 0x9C00704C 0x00000001
machine.memory.poke.l 0x9C007014 0xFFFFFFFF
assert ${machine.memory.peek.l(0x9C00701C) == 1}          "func $0C CachePixPat declined"

# op $72 selects the cached tile into slot 1; fill a 8x2 rect at (0, 88).
# (Queue records APPEND at the already-drained offset $1EC — the drain is
# incremental against the published count at CB+$1C0.)
machine.memory.poke.l 0x9C0078C0 0x00690008
machine.memory.poke.l 0x9C0078C4 0x00720001
machine.memory.poke.l 0x9C0078C8 0xDEAD0001
machine.memory.poke.l 0x9C0078CC 0x00050000
machine.memory.poke.l 0x9C0078D0 0x00000058
machine.memory.poke.l 0x9C0078D4 0x00020060
machine.memory.poke.l 0x9C0071C0 0x00000204
assert ${machine.memory.peek.l(0x9C011458) == 0x20406080}  "PixPat row 0 lo != 20406080"
assert ${machine.memory.peek.l(0x9C01145C) == 0x20406080}  "PixPat row 0 hi != 20406080"
assert ${machine.memory.peek.l(0x9C011858) == 0x20406080}  "PixPat row 1 != 20406080"

# func $2C FlushPixPat (arg = the handle) invalidates the type-5 entry.
machine.memory.poke.l 0x9C00764C 0xDEAD0001
machine.memory.poke.l 0x9C007048 0x0000002C
machine.memory.poke.l 0x9C00704C 0x00000002
machine.memory.poke.l 0x9C007014 0xFFFFFFFF
assert ${machine.memory.peek.l(0x9C00701C) == 1}          "func $2C FlushPixPat failed"

# --- func $15 blit from an UNLOCKED offscreen (pmVersion 2): the src
#     baseAddr is the pixel-image HANDLE; the card dereferences the master
#     pointer.  Src: 8 bytes 10..17 at $400100, handle at $4000F0.  Request
#     block staged at CB+$58 exactly as GCQD ships it; srcCopy to (0,100). ---
machine.memory.poke.l 0x004000F0 0x00400100
machine.memory.poke.l 0x00400100 0x10111213
machine.memory.poke.l 0x00400104 0x14151617
# dst PixMap copy: baseAddr = screen, rowBytes $8400, bounds (0,0,480,640), pixelSize 8
machine.memory.poke.l 0x9C007058 0x00009C01
machine.memory.poke.l 0x9C00705C 0x14008400
machine.memory.poke.l 0x9C007060 0x00000000
machine.memory.poke.l 0x9C007064 0x01E00280
machine.memory.poke.l 0x9C007078 0x00080008
# src PixMap copy at +$36: baseAddr = HANDLE $4000F0, rowBytes $8008,
# bounds (0,0,1,8), pmVersion 2 at +$E, pixelSize 8 at +$20
machine.memory.poke.l 0x9C00708C 0x00000040
machine.memory.poke.l 0x9C007090 0x00F08008
machine.memory.poke.l 0x9C007094 0x00000000
machine.memory.poke.l 0x9C007098 0x00010008
machine.memory.poke.l 0x9C00709C 0x00020000
machine.memory.poke.l 0x9C0070AC 0x00080008
# no mask
machine.memory.poke.l 0x9C0070C2 0x00000000
# dstRect (100,0,101,8) / srcRect (0,0,1,8) at +$A8/+$B0
machine.memory.poke.l 0x9C007100 0x00640000
machine.memory.poke.l 0x9C007104 0x00650008
machine.memory.poke.l 0x9C007108 0x00000000
machine.memory.poke.l 0x9C00710C 0x00010008
# regions absent
machine.memory.poke.l 0x9C007118 0x00000000
machine.memory.poke.l 0x9C00711C 0x00000000
machine.memory.poke.l 0x9C007120 0x00000000
# fg black / bk white RGBs at +$E8/+$EE (B/W colorize envelope)
machine.memory.poke.l 0x9C007140 0x00000000
machine.memory.poke.l 0x9C007144 0x0000FFFF
machine.memory.poke.l 0x9C007148 0xFFFFFFFF
machine.memory.poke.l 0x9C00714C 0xFFFF0000
machine.memory.poke.l 0x9C007048 0x00000015
machine.memory.poke.l 0x9C00704C 0x00000003
machine.memory.poke.l 0x9C007014 0xFFFFFFFF
assert ${machine.memory.peek.l(0x9C00701C) == 1}          "func $15 declined the pmVersion-2 source"
assert ${machine.memory.peek.l(0x9C02A400) == 0x10111213} "offscreen blit row lo"
assert ${machine.memory.peek.l(0x9C02A404) == 0x14151617} "offscreen blit row hi"

# --- func $15 SCREEN->SCREEN (the ScrollRect shape): src PixMap IS the
#     screen (baseAddr $9C011400, pmVersion 0).  The card must read the
#     source from its OWN framebuffer: a guest-space read of the super-slot
#     address resolves through the guest's CURRENT addressing mode, and under
#     a booted OS idling in 24-bit mode it aliases onto host RAM — the System
#     Info scroll benchmark scrolled noise.  (At this test's power-on state
#     there is no 24-bit translation, so this case pins the screen->screen
#     CONTRACT — src pixels land at the dst, source row preserved — but the
#     aliasing itself only reproduces under a booted OS.)
#     Copy row 100 (blitted above) to row 102. ---
machine.memory.poke.l 0x9C00708C 0x00009C01
machine.memory.poke.l 0x9C007090 0x14008400
machine.memory.poke.l 0x9C007094 0x00000000
machine.memory.poke.l 0x9C007098 0x01E00280
machine.memory.poke.l 0x9C00709C 0x00000000
# dstRect (102,0,103,8) / srcRect (100,0,101,8)
machine.memory.poke.l 0x9C007100 0x00660000
machine.memory.poke.l 0x9C007104 0x00670008
machine.memory.poke.l 0x9C007108 0x00640000
machine.memory.poke.l 0x9C00710C 0x00650008
machine.memory.poke.l 0x9C007048 0x00000015
machine.memory.poke.l 0x9C00704C 0x00000004
machine.memory.poke.l 0x9C007014 0xFFFFFFFF
assert ${machine.memory.peek.l(0x9C00701C) == 1}          "func $15 declined the screen->screen copy"
assert ${machine.memory.peek.l(0x9C02AC00) == 0x10111213} "screen->screen copy row lo"
assert ${machine.memory.peek.l(0x9C02AC04) == 0x14151617} "screen->screen copy row hi"
assert ${machine.memory.peek.l(0x9C02A400) == 0x10111213} "screen->screen copy clobbered the source row"

quit
