machine.memory.poke.l 0x9C007748 0x11111111
machine.memory.poke.l 0x9C00774C 0x00000000
machine.memory.poke.l 0x9C007750 0x00050000
machine.memory.poke.l 0x9C007754 0x00000020
machine.memory.poke.l 0x9C007758 0x00020024
machine.memory.poke.l 0x9C00775C 0x00643030
