# Integration test: IIcx + 8•24 GC — 8-bpp colour rasterizer math, exact bytes.
#
# Drives the DrawMultiObject queue directly (same poke transport as
# iicx-824gc) with the screen at 8 bpp and asserts hand-computed framebuffer
# bytes on the power-on CLUT (grey ramp, with the 1-bpp mono seed clut[0] =
# white / clut[1] = black — Mac convention, bg pixel 0 = white):
#
#   * arithmetic transfer modes $20-$27 (qd-transfer-modes §3.1): 16-bit
#     component math on CLUT entries, result via the card-side Color2Index —
#     blend (default $7FFF weight = 50/50), addPin (carry/pin clamp), addOver
#     (wraps), subPin (borrow/pin clamp), transparent (full-pixel compare
#     against transColor = the port bk pixel: skip on match, plain copy
#     otherwise), adMax, subOver (wraps), adMin;
#   * op $74 opRGBPat (MakeRGBPat's 2×2 ordered dither): mid-grey $8000
#     quantizes to level 6 -> DthrTbl13 row {AAAA,5555,5555,AAAA} -> the exact
#     aa/55 checkerboard, anchored to the port grid.
#
# Layout: case i = a 4×2 rect at (0, 8i), first painted with a known base grey
# via patCopy, then hit with one arithmetic fill.  Every expected byte below
# is the exact 16-bit math result: e.g. blend = (40×½ + 80×½) = 60; addOver =
# (8080+C0C0) mod 10000 = 4140 -> nearest ramp index 41.

machine.nubus.video_card = "824gc"
machine.nubus.video_mode = "gc_640x480_8bpp"
machine.boot "iicx" 8192
machine.rom.reload

# Accelerator bring-up + SetPort (staged port record: screen base, origin 0).
machine.memory.poke.l 0x9C006400 0x42005300
machine.memory.poke.l 0x9C007048 0x00000001
machine.memory.poke.l 0x9C00704C 0x00000000
machine.memory.poke.l 0x9C007014 0xFFFFFFFF
machine.memory.poke.l 0x9C00717E 0x9C011400
machine.memory.poke.l 0x9C007184 0x00000000
machine.memory.poke.l 0x9C007048 0x0000002D
machine.memory.poke.l 0x9C00704C 0x00000000
machine.memory.poke.l 0x9C007014 0xFFFFFFFF
assert ${machine.memory.peek.l(0x9C00701C) == 1}         "SetPort (func $2D) not accepted at 8 bpp"

machine.memory.poke.l 0x9C0076D4 0x00710001
machine.memory.poke.l 0x9C0076D8 0xFFFFFFFF
machine.memory.poke.l 0x9C0076DC 0xFFFFFFFF
machine.memory.poke.l 0x9C0076E0 0x00690008
