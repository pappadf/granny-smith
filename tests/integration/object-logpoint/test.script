# M5 integration: logpoint messages use ${...} interpolation.
#
# The VBL handler bumps Ticks ($00016A.l) once per VBL — set a write
# logpoint there with a message that exercises:
#   ${cpu.pc}              — alias-table-backed register read
#   ${lp.value:08x}        — synthetic lp context, format spec
#   ${lp.addr:08x}         — synthetic lp.addr
#   ${lp.size}             — default formatter
# After running long enough for at least one VBL, the harness
# captures the formatted line and the run continues to `quit`.

log_set memory 5
log_set logpoint 5

logpoint_set "--write 0x000016A.l "Ticks bumped pc=${cpu.pc} addr=${lp.addr:08x} val=${lp.value:08x} size=${lp.size}" level=5"

run 5000000

logpoint_list_dump
quit
