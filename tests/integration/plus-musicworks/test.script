# Plus + MusicWorks 0.42 — boot the MFS floppy to the Finder, open
# Samples/"Brandenburg #3" in MusicWorks, click PLAY, and golden-match a
# window of the four-voice PWM music (see config.mk).
#
# Double-clicks are two press/release pairs 200K instructions apart (~0.3 s
# guest time, inside the default double-click interval). All coordinates are
# Plus-screen absolute (512x342).
#
# Regenerate the goldens by replacing the screen.match lines with
# machine.screen.save and the sound stop/match pair with
#   machine.sound.capture.stop music.wav
# then audition the WAV once before committing it.

# Pin the RTC so the run is deterministic run-to-run. (The harness booted the
# machine already — no machine.boot here, so the pin sticks.)
machine.rtc.time = 3000000000

# Boot the 400K MFS floppy to the Finder desktop.
scheduler.run 65400000
machine.screen.match finder.png

# Open "MusicWorks Disk" (icon at top right).
machine.adb.mouse.move 465 45
scheduler.run 2100000
machine.adb.mouse.click true
scheduler.run 200000
machine.adb.mouse.click false
scheduler.run 200000
machine.adb.mouse.click true
scheduler.run 200000
machine.adb.mouse.click false
scheduler.run 16300000

# Open the "Samples" folder inside the disk window.
machine.adb.mouse.move 228 90
scheduler.run 2100000
machine.adb.mouse.click true
scheduler.run 200000
machine.adb.mouse.click false
scheduler.run 200000
machine.adb.mouse.click true
scheduler.run 200000
machine.adb.mouse.click false
scheduler.run 16300000
machine.screen.match samples.png

# Open "Brandenburg #3" (first icon in the Samples window) — launches
# MusicWorks from the same floppy and loads the document.
machine.adb.mouse.move 103 210
scheduler.run 2100000
machine.adb.mouse.click true
scheduler.run 200000
machine.adb.mouse.click false
scheduler.run 200000
machine.adb.mouse.click true
scheduler.run 200000
machine.adb.mouse.click false
scheduler.run 65400000
machine.screen.match musicworks-loaded.png

# Click PLAY. MusicWorks first spends ~4.5 s initializing its PWM buffers
# (constant full-scale DC — silent through the AC-coupled speaker); the run
# below skips past that so the golden is the music itself.
machine.adb.mouse.move 310 33
scheduler.run 2100000
machine.adb.mouse.click true
scheduler.run 300000
machine.adb.mouse.click false
scheduler.run 3200000

# Capture ~7.7 s of the music and compare sample-exactly.
machine.sound.capture.start
scheduler.run 5400000
machine.sound.capture.stop

assert ${machine.sound.capture.frames == 168765} "unexpected capture length"
machine.sound.match music.wav

quit
