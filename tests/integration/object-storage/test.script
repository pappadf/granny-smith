# M8 (slice 2) integration: `storage` object class.
# Plus boots with one SCSI HD (hd1.img) and one floppy (System 6.0.8).
# storage.images should enumerate at least these two entries.

run 50000

# Tree shape.
eval storage
storage.images

# First image: HD attached at boot.
storage.images[0]
storage.images[0].index
storage.images[0].filename
storage.images[0].type
storage.images[0].writable
storage.images[0].raw_size

# Second image: the System 6 floppy.
storage.images[1].filename
storage.images[1].type

# storage.import — copy a small file to a chosen destination via the
# legacy `cp` route, then verify storage.import without dst_path
# falls back to the content-hash naming under /opfs/images/.
echo $(storage.import("../../data/roms/Plus_v3.rom", "/tmp/imported_rom.bin"))

quit
