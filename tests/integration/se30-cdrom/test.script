# Integration test: SE/30 CD-ROM
# Boots SE/30 from a 1.44MB floppy (System 7.0.1) with a SCSI CD-ROM
# device attached via cdrom= CLI argument.
# Verifies Finder desktop, exercises cdrom commands (info/eject).

# Boot to Finder desktop (8MB RAM needs more cycles for memory test)
scheduler.run 2000000000

# Verify the screen matches the Finder desktop reference image.
# The CD-ROM is on the bus but System 7.0.1 floppy does not include
# the Apple CD-ROM extension, so no disc icon appears — this proves
# the CD-ROM device does not break normal boot.
screen.match finder.png

# Verify cdrom info reports the attached disc
scsi.devices[3].info

# Eject the disc
scsi.devices[3].eject

# Verify cdrom info shows no disc after eject
scsi.devices[3].info

# Run briefly to let the OS process the SCSI bus change
scheduler.run 100000000

# Verify the desktop is still stable after CD-ROM eject
screen.match finder.png

quit
