# IIfx A/UX 3.0.1 — log in with an X11 session type.
#
# Boots the IIfx to the A/UX 3.0.1 graphical login window (identical to
# iifx-aux3-boot), then instead of logging straight in:
#
#   1. Options menu -> "Change Session Type..." opens the modal chooser.
#   2. Type the user name "root" into the dialog's Name field.
#   3. Select "X11" from the session-type list (Console Emulator /
#      A/UX Finder 24-bit / A/UX Finder 32-bit / X11).
#   4. Press Return to commit the Name field — this enables the
#      "Every Session" / "This Session Only" buttons (they are disabled
#      until the name is committed).
#   5. Click "This Session Only" to set X11 as the session type for this
#      login only; the dialog closes back to the login window with "root"
#      pre-filled.
#   6. Click "Login" (root has an empty password).
#
# A/UX then runs x11start instead of the A/UX Finder, so the desktop that
# comes up is a pure X11 root window (the grey stipple) with the "console"
# xterm and two "localhost" login-shell xterms — no Mac Finder.
#
# All input goes through the "aux" mouse-routing path (the A/UX cursor
# globals), the same path se30-aux3-boot uses for its login-window clicks.

# Pin the wall clock so screenshot comparisons are reproducible (matches
# iifx-aux3-boot).
machine.rtc.time = 2026-04-26T21:30:36

# ~1.5 G cycles takes the IIfx through Mac OS boot, the A/UX launch, the
# A/UX kernel, the UFS root mount, exec(/etc/init), fsck, and to the
# graphical CommandShell login window (bitwise-stable from ~1.3 G on).
scheduler.run 1500000000

assert ${machine.id == "iifx"} "machine.id != iifx"
assert ${machine.rom.checksum == "4147DD77"} "rom.checksum != 4147DD77"
assert ${machine.screen.width == 640} "screen.width != 640"
assert ${machine.screen.height == 480} "screen.height != 480"

# Sanity: we are at the same login window iifx-aux3-boot pins (compare the
# blinking-cursor-free Name-field region).
machine.screen.match login.png 240 318 258 323

# --- Options menu -> "Change Session Type..." --------------------------------
# "Options" is the second menu-bar title (~x=66, y=9).  Press and hold, drag
# down to the second item "Change Session Type... (Cmd-S)" (~y=43), release.
machine.adb.mouse.move 66 9 "aux"
scheduler.run 5000000
machine.adb.mouse.click true
scheduler.run 10000000
machine.adb.mouse.move 100 43 "aux"
scheduler.run 10000000
machine.adb.mouse.click false
scheduler.run 30000000

# --- Type the user name "root" into the dialog's Name field ------------------
# ADB scancodes: r=0x0F, o=0x1F, o=0x1F, t=0x11.
machine.adb.keyboard.press 0x0F
scheduler.run 2000000
machine.adb.keyboard.press 0x1F
scheduler.run 2000000
machine.adb.keyboard.press 0x1F
scheduler.run 2000000
machine.adb.keyboard.press 0x11
scheduler.run 5000000

# --- Select "X11" from the session-type list ---------------------------------
# The list shows Console Emulator / A/UX Finder (24-bit) / A/UX Finder
# (32-bit) / X11; the "X11" row is the fourth, at ~(250, 212).
machine.adb.mouse.move 250 212 "aux"
scheduler.run 5000000
machine.adb.mouse.click true
scheduler.run 2000000
machine.adb.mouse.click false
scheduler.run 10000000

# --- Commit the Name field, then choose "This Session Only" ------------------
# Return commits the typed name, which enables the two session buttons.
machine.adb.keyboard.press return
scheduler.run 30000000
# "This Session Only" button (~452, 228): set X11 for this session; the
# dialog closes back to the login window with "root" still in the Name field.
machine.adb.mouse.move 452 228 "aux"
scheduler.run 5000000
machine.adb.mouse.click true
scheduler.run 3000000
machine.adb.mouse.click false
scheduler.run 40000000

# --- Log in (root has an empty password) -------------------------------------
# The "Login" button is centred under the Name/Password fields (~348, 307).
machine.adb.mouse.move 348 307 "aux"
scheduler.run 5000000
machine.adb.mouse.click true
scheduler.run 3000000
machine.adb.mouse.click false
# x11start brings up the X server, window manager and the console/localhost
# xterms; the desktop is a settled, bitwise-stable plateau by ~300 M cycles
# after the click (checksum verified constant across a further 80 M).  400 M
# lands comfortably on the settled frame.
scheduler.run 400000000

# The X11 desktop: the grey stipple root window with the "console" xterm and
# two "localhost" login-shell xterms — NOT the Mac-style A/UX Finder desktop.
machine.screen.match x11-desktop.png

quit
