# Top-level root methods.
# `objects(path)` lists children at the resolved path (or root when
# path is omitted). `attributes(path)` and `methods(path)` enumerate
# the resolved class. `help(path)` returns a doc string. `time()`
# returns wall-clock seconds.

scheduler.run 50000

# objects() at the root: should include cpu / memory / scsi / floppy /
# debugger / network / input / storage etc. The legacy harness checks
# stdout for substring matches so we only need the names to appear
# somewhere in the JSON list output.
echo ${objects()}

# objects("cpu") drills in. cpu has no child objects on Plus (no FPU
# without --fpu), so the list is empty — but it must resolve cleanly.
echo ${objects("cpu")}

# attributes("cpu") names the per-register getters.
echo ${attributes("cpu")}

# methods("cpu") is currently empty (cpu has only attributes), so the
# call is a path-resolves-cleanly test.
echo ${methods("cpu")}

# methods("rtc") includes pram_read, pram_write.
echo ${methods("rtc")}

# help() on a member returns its doc string.
echo ${help("cpu.pc")}
echo ${help("rtc.time")}
echo ${help("mouse.move")}

# time() is just monotonic-ish; we don't pin a value, only that the
# call resolves.
echo ${time()}

# Process-singleton wrappers: each method must resolve and either
# succeed or fail with a clean error (no crash). The headless runs
# from this test's directory (tests/integration/object-root-methods)
# so the ROM lives at ../../data/roms/Plus_v3.rom — a relative path
# that works in both the dev container and the GitHub Actions runner.
echo ${rom.identify("../../data/roms/Plus_v3.rom")}
echo ${rom.checksum_of("../../data/roms/Plus_v3.rom")}

# methods() at the root should now include the wrappers above.
echo ${methods()}

# quit() is the last call — same as the legacy `quit` command.
echo ${quit()}
