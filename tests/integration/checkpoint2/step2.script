# Step 2: Boot from SCSI HD, load checkpoint, continue to desktop

# Load the checkpoint saved in step 1 (restores to 50M instruction point with floppy)
# Loaded from current working directory (test-results/checkpoint2/)
checkpoint_load checkpoint.gs

# Run 50M more instructions (should reach desktop just like step 1 would)
run 100000000

#
screen.match ../../checkpoint2/desktop.png

run 100000000

mouse.move 25 10
run 1000000
mouse.click true
run 1000000
mouse.move 25 30
run 1000000
mouse.click false

run 100000000

# Save screenshot for debugging, then verify against reference
screen.save screenshot-step2.png

quit
