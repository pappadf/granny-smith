# Step 2: Boot from SCSI HD, load checkpoint, continue to desktop

# Load the checkpoint saved in step 1 (restores to 50M instruction
# point with floppy). Loaded from current working directory
# (test-results/checkpoint2/). Assert so a load failure aborts the
# step before screen.match runs against an unrestored machine.
assert ${checkpoint.load("checkpoint.gs")} "checkpoint2 step2 load failed"

# Run 50M more instructions (should reach desktop just like step 1 would)
scheduler.run 100000000

#
screen.match ../../checkpoint2/desktop.png

scheduler.run 100000000

mouse.move 25 10
scheduler.run 1000000
mouse.click true
scheduler.run 1000000
mouse.move 25 30
scheduler.run 1000000
mouse.click false

scheduler.run 100000000

# Save screenshot for debugging, then verify against reference
screen.save screenshot-step2.png

quit
