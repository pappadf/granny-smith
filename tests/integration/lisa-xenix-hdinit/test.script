# SCO Xenix 3.0 — hard-disk initialization (hdinit) on the Apple Lisa 2.
# See config.mk for the procedure (XENIX Installation Guide May-1984 §1.5.1-1.5.2).
#
# Keyboard input uses raw Lisa COPS scancodes via keyboard.press: a key is
# pressed (down = 0x80|keycode) then released (up = keycode) back-to-back, with a
# short run between characters.  Holding a key (running between down and up) would
# trip Xenix's software auto-repeat, so the down/up pairs are always adjacent.
# Keycodes: h=6b d=7b i=53 n=6f t=66 y=67 5=64 Return=48 (so down = +0x80).

# Attach a blank in-memory ProFile to the parallel port (the Lisa 2/5 install
# target).  Without it the kernel panics "pf0 not on line".
machine.hd.attach
assert machine.id == "lisa" "machine.id != lisa"
assert machine.rom.checksum == "098917B2" "rom.checksum != 098917B2 (rev-H)"
assert machine.hd.present == true "ProFile should be attached"

# (§1.5.1) Boot the floppy to the loader's "boot :" prompt (a COPS poll loop).
scheduler.run 60000000
machine.screen.match expected_bootprompt.png

# The ROM's pre-handoff COPS re-init leaves the loader's protocol decoder in its
# 3-byte-report state, so the first injected key is swallowed; send a dummy key to
# clear it, then RETURN to load the kernel from fd(2,0)xenix.
machine.adb.keyboard.press 0xC8
scheduler.run 3000000
machine.adb.keyboard.press 0xC8
machine.adb.keyboard.press 0x48
scheduler.run 120000000
# Kernel booted to the boot-floppy single-user shell ("<BootFloppy>").
machine.screen.match expected_bootfloppy.png

# (§1.5.2) Type "hdinit" + RETURN.
machine.adb.keyboard.press 0xEB
machine.adb.keyboard.press 0x6B
scheduler.run 600000
machine.adb.keyboard.press 0xFB
machine.adb.keyboard.press 0x7B
scheduler.run 600000
machine.adb.keyboard.press 0xD3
machine.adb.keyboard.press 0x53
scheduler.run 600000
machine.adb.keyboard.press 0xEF
machine.adb.keyboard.press 0x6F
scheduler.run 600000
machine.adb.keyboard.press 0xD3
machine.adb.keyboard.press 0x53
scheduler.run 600000
machine.adb.keyboard.press 0xE6
machine.adb.keyboard.press 0x66
scheduler.run 600000
machine.adb.keyboard.press 0xC8
machine.adb.keyboard.press 0x48
scheduler.run 30000000
# "WARNING: ... Do you want to continue <y/n>?"
machine.screen.match expected_continue.png

# Answer "y" + RETURN.
machine.adb.keyboard.press 0xE7
machine.adb.keyboard.press 0x67
machine.adb.keyboard.press 0xC8
machine.adb.keyboard.press 0x48
scheduler.run 20000000
# "Enter size of hard disk (5 or 10):"
machine.screen.match expected_size.png

# Answer "5" (5 MB ProFile) + RETURN.  hdinit builds the filesystem, runs fsck,
# writes the boot block, then shuts the system down.
machine.adb.keyboard.press 0xE4
machine.adb.keyboard.press 0x64
machine.adb.keyboard.press 0xC8
machine.adb.keyboard.press 0x48
scheduler.run 150000000
# "Disk initialization complete. / ** Normal System Shutdown **"
machine.screen.match expected_complete.png

quit
