# Integration test: Macintosh IIci Floppy Boot + About box
# Boots the IIci from the System 7.0.1 1.44MB HD floppy (same image as
# se30-floppy-hd / iifx-boot), verifies the Finder desktop, then brings up
# the "About This Macintosh" dialog via the Apple menu.
#
# The IIci's RBV chip ($50F26000) replaces the IIcx VIA2 and drives built-in
# video: the boot ROM waits on the RvIRQ0 vertical-blank interrupt during
# video init, then QuickDraw draws to ScrnBase $FBB08000 (the slot-$B
# framebuffer aperture).  A single fixed instruction budget reaches a stable
# desktop deterministically (no boot-drive-discovery poke needed, unlike the
# Universal-ROM se30-floppy test).

scheduler.run 360000000

assert ${machine.id == "iici"} "machine.id != iici"
assert ${machine.rom.checksum == "368CADFE"} "rom.checksum != 368CADFE"
assert ${machine.screen.width == 640} "screen.width != 640"
assert ${machine.screen.height == 480} "screen.height != 480"

# Verify the Finder desktop matches the reference (System 7 menu bar, the
# Disk Tools floppy icon, Trash icon, gray desktop).
machine.screen.match finder.png

# Bring up "About This Macintosh" via the Apple menu.  The mouse
# *geometry* matches the other models (Apple menu at 25,10; the first menu
# item at 25,30), but positioning uses "global" mode (direct MTemp writes +
# guard, as in iifx-boot) — the IIci's classic VIA1 ADB delta path does not
# land the cursor precisely enough for a pixel-exact menu pick.  The button
# press/release still goes through the ADB (default mouse.click).
machine.adb.mouse.move 50 50 "global"
scheduler.run 5000000
machine.adb.mouse.move 25 10 "global"
scheduler.run 3000000
machine.adb.mouse.click true
scheduler.run 6000000
machine.adb.mouse.move 25 30 "global"
scheduler.run 6000000
machine.adb.mouse.click false
scheduler.run 45000000

# The About box shows "Total Memory 8,192K" (RAM pinned in config.mk), so
# the rendered dialog is reproducible.
machine.screen.match about.png

quit
