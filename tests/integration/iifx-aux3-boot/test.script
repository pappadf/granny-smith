# IIfx A/UX 3.0.1 HD Boot — boots all the way to the A/UX login prompt.
#
# Drives the IIfx through the full SCSI HD boot path: Mac OS boot → the
# "A/UX Startup" set-startup app → "Welcome to A/UX. Launching..." → the
# A/UX kernel _start → autoconfig → vfs_mountroot (UFS) → the real mount →
# exec(/etc/init) → userland → fsck → the A/UX `login:` prompt.
#
# HISTORY (each pin replaced as the boot advanced — see
# local/gs-docs/notes/iifx-debug/ for the full archaeology):
#   1. mac-finder.png        — stuck at Mac OS Finder (pre-iHSKEN-write fix).
#   2. launching.png         — "Welcome to A/UX. Launching..." then idle.
#   3. no-root-fs-panic.png  — "panic: no root file system".
#   4. post-mount-stuck.png  — blank gray after mount; kernel pre-userland.
#   ... then: libc1_s exec-load, init fork, fsck, and a long stall on
#   "/: bad dir ino 15360 ... mangled entry" (the /dev page $301a00 was
#   overrun by a scattered bus-master SCSI READ).
#
# THE FIX (this pin): the IIfx bus-master SCSI driver does scatter-gather
# by re-arming the SCSIDMA once per SG segment WITHIN a single SCSI command
# (state machine SG_RUN->SG_DMA->SG_EOP->SG_RUN, re-programming
# chip[$100]=SG[sg_idx].b_addr each segment).  Our 53C80 model wrongly
# forced data_in->STATUS on every DMA-segment EOP, which made the driver
# complete+re-issue one overlapping READ per segment with sg_idx reset to
# 0 — so every segment re-used SG[0] and a physically-scattered buffer was
# filled contiguously, overrunning /dev.  The fix (src/core/peripherals/
# scsi.c scsi_signal_eop): a DMA-segment EOP keeps the bus in data_in and
# raises end-of-DMA; the target releases to STATUS only when its data is
# exhausted.  The kernel then programs each scattered segment itself, /dev
# is intact, and the boot reaches login.
#
# CURRENT EXPECTED STATE
# ----------------------
# Screen: the A/UX text console at the `login:` prompt
#   "Apple Computer Inc. A/UX (notnamed) / login:"
# (Reached via getty: /etc/macgetty is not executable on this image, so
# A/UX launches the text getty instead of the graphical login that the
# SE/30 reaches — a smaller residual tracked in the iifx-debug notes.
# A few "bad block ..." fsck messages are also visible.)

# Pin the wall clock so screenshot comparisons are reproducible.
rtc.time = 2026-04-26T21:30:36

# ~1.5 G cycles takes the IIfx through Mac OS boot, A/UX launch, the A/UX
# kernel, autoconfig, the UFS root mount, exec(/etc/init), fsck, and to the
# `login:` prompt.  The login screen is bitwise-stable from ~1.3 G onward
# (verified: identical screen.checksum at 1.3/1.4/1.5/1.6 G), so the 1.5 G
# budget lands comfortably on a settled frame.
scheduler.run 1500000000

assert ${machine.id == "iifx"} "machine.id != iifx"
assert ${rom.checksum == "4147DD77"} "rom.checksum != 4147DD77"

# Default IIfx slot table seats the JMFB card; the panel is 640x480 at 1 bpp.
assert ${screen.width == 640} "screen.width != 640"
assert ${screen.height == 480} "screen.height != 480"

# Bitwise compare against the captured A/UX `login:` prompt.  When the boot
# advances further (e.g. past getty to the graphical login once the write
# path / residual is fixed) this will stop matching and the pin should be
# updated.
screen.match login.png

quit
