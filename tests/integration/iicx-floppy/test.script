# Integration test: IIcx System 7.0.1 Floppy Boot
# Boots IIcx from the System 7.0.1 1.44 MB MFM floppy, lands on the
# Finder desktop, then opens "About This Macintosh" — which on this
# build identifies the machine as "Macintosh IIcx" with the configured
# RAM size. Matches the structure of the SE/30 floppy-hd test.

# Boot to Finder desktop (8 MB RAM — same budget as se30-floppy-hd).
scheduler.run 2000000000

assert ${machine.id == "iicx"} "machine.id != iicx"
assert ${screen.width == 640} "screen.width != 640"
assert ${screen.height == 480} "screen.height != 480"

# Verify the screen matches the Finder desktop reference image.
screen.match finder.png

# Bring up the "About This Macintosh..." window via the Apple menu.
mouse.move 25 10 "global"
scheduler.run 4000000
mouse.click true
scheduler.run 20000000
mouse.move 25 30 "global"
scheduler.run 40000000
mouse.click false
scheduler.run 100000000

screen.match about.png

quit
