# M6 integration: debugger.breakpoints / .logpoints / .watches
# indexed-child surface. Verifies:
#   - debugger root resolves and lists three children
#   - debugger.breakpoints.add(addr) adds a breakpoint AND the
#     entry is reachable via debugger.breakpoints.<id>
#   - sparse stable indices: removing #0 does not renumber #1
#   - legacy `break set` and the new method share the same store
#   - per-entry attributes (addr, hit_count, condition, id) work
#   - .remove() detaches the entry (subsequent reads error cleanly)

run 50000

# The debugger object resolves to a class instance.
eval debugger
debugger.breakpoints
debugger.logpoints
debugger.watches

# Add via the new method, capturing into the breakpoint store.
echo $(debugger.breakpoints.add(0x400100))
echo $(debugger.breakpoints.add(0x400200))

# Index 0 and 1 should now be live with the addresses we set.
debugger.breakpoints.0.addr
debugger.breakpoints.0.id
debugger.breakpoints.1.addr

# Legacy `break list` must see the same entries (single store).
break_list_dump

# Remove #0 via the method. #1 stays at id 1 — sparse indices.
# Inside $(...) the index uses bracket form (the dotted form is for paths
# in eval / shell, the expression parser keeps `.<ident>` only).
echo $(debugger.breakpoints[0].remove())
debugger.breakpoints.1.addr

# The next add gets id=2 (max-id-ever + 1; never recycled).
echo $(debugger.breakpoints.add(0x400300))
debugger.breakpoints.2.addr

# Conditional breakpoint via the method form (M6's predicate field).
echo $(debugger.breakpoints.add(0x400400, "cpu.d0 == 0"))
debugger.breakpoints.3.addr
debugger.breakpoints.3.condition

# Clear via the new collection method, verify legacy list is empty too.
echo $(debugger.breakpoints.clear())
break_list_dump

quit
