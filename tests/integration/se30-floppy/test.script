# Integration test: SE/30 Floppy Boot
# Boots SE/30 from a System 7.1 floppy disk and verifies the display.

# Boot to Finder desktop
run 800000000

# Verify the screen matches the reference image
screenshot match finder.png

mouse.move 50 50

run 5000000

mouse.move 25 10
run 2000000
mouse.click true
run 4000000
mouse.move 25 30
run 2000000
mouse.click false

run 45000000

screenshot match about.png

quit
