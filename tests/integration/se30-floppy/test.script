# Integration test: SE/30 Floppy Boot
# Boots SE/30 from a System 7.1 floppy disk and verifies the display.

# Boot to Finder desktop.
# Skip the Universal ROM's ~13 s boot-drive-discovery wait at $40801610
# (poke $8805 into $017A, clear it after one inner-poll cycle).  See
# tests/integration/iicx-video-modes/test.script for the mechanics.
scheduler.run 40000000
memory.poke.w 0x017A 0x8805
scheduler.run 2000000
memory.poke.w 0x017A 0
scheduler.run 700000000

# Verify the screen matches the reference image
screen.match finder.png

mouse.move 50 50

scheduler.run 5000000

mouse.move 25 10
scheduler.run 2000000
mouse.click true
scheduler.run 4000000
mouse.move 25 30
scheduler.run 2000000
mouse.click false

scheduler.run 45000000

screen.match about.png

quit
