# Integration test: SE/30 Floppy Boot
# Boots SE/30 from a System 7.1 floppy disk and verifies the display.

# Boot to Finder desktop
run 200000000

# Verify the screen matches the reference image
screenshot --match floppy.png

set-mouse 25 10
run 1000000
mouse-button down
run 1000000
set-mouse 25 30
run 1000000
mouse-button up

run 100000000

screenshot foobar.png

quit
