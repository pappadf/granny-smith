# SE/30 A/UX 3.0.1 Boot (retail SE floppy).
#
# Verifies the volname-shift fix renders "Untitled" correctly, and that
# clicks on "Easy Install" and "OK" both land on their targets.
#
# Mouse positioning under A/UX uses --aux mode (not --global): A/UX is
# Unix, and the 1ms guard tick installed by --global stomps A/UX kernel
# data at PA $0828 whenever the CPU happens to be in supervisor mode at
# the tick boundary.  --aux uses a user-mode-only guard tick, so it pins
# MAE's MTemp without corrupting the kernel.

run 200000000

screenshot match installer.png

# Click "Easy Install" (button center ~(380, 80)) — opens a confirm
# dialog asking "...will be overwritten by the installation process.
# Do you wish to continue?" with Cancel / OK buttons.
set-mouse 380 80 --aux
mouse-button down
run 5000000
mouse-button up
run 25000000

screenshot match confirm.png

# Click "OK" (button center ~(337, 185)) — confirms and dismisses the
# dialog, transitioning to the install-progress screen.  The cursor is
# hidden by the dialog, but the click still hit-tests against MTemp
# (which --aux keeps pinned at our target), so the click lands on OK.
set-mouse 337 185 --aux
mouse-button down
run 1000000
mouse-button up
run 2000000

# At this point the confirm dialog has been dismissed.  The install
# progress screen briefly flashes "Determining which files will be
# needed..." and then transitions to a gray screen with a wait cursor
# while the installer scans the CD.  We capture the brief gray-screen
# state right after dismissal — confirm dialog is gone and the
# installer hasn't yet drawn the progress UI.
screenshot match dialog-dismissed.png

run 750000000

# This is an UNWANTED match -> match does NOT equal success
screenshot match error.png

quit
