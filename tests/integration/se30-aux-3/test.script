# Integration test: SE/30 A/UX 3.0.1 Boot
# Boots SE/30 from the A/UX 3.0.1 Installation Boot Disk
# with the A/UX 3.0.1 Install CD-ROM and SCSI HD attached.
# The installer finds the CD and loads far enough to show
# loading screen

# Boot from A/UX Installation Boot Disk (with CD-ROM and HD attached)
run 100000000

# Verify the A/UX loading screen appears
screenshot --match loading.png

quit
