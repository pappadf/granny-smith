# Apple Lisa 2 — boot SCO Xenix 3.0 from the ProFile with NO floppy (see config.mk).
#
# Keyboard input is raw Lisa COPS scancodes via keyboard.press (down = 0x80|kc,
# release = kc).  The ROM STARTUP FROM picker is driven with Apple-N hotkeys
# (Apple = COPS 0xFF down / 0x7F up; digit 3 = 0xF2 down / 0x72 up); the loader's
# "boot :" prompt is pre-filled with the default pf(0,0)xenix, so a bare Return
# (0xC8/0x48) boots it.

machine.hd.attach "$WORK_DIR/profile.image"
assert machine.id == "lisa" "machine.id != lisa"
assert machine.rom.checksum == "098917B2" "rom.checksum != 098917B2 (rev-H)"
assert machine.hd.present == true "ProFile should be attached"

# === No floppy: the ROM "insert diskette / STARTUP FROM…" screen =============
scheduler.run 200000000
machine.screen.match expected_nofloppy.png

# === Apple-3 → the ROM STARTUP FROM device picker ===========================
machine.adb.keyboard.press 0xFF
scheduler.run 200000
machine.adb.keyboard.press 0xF2
scheduler.run 200000
machine.adb.keyboard.press 0x72
scheduler.run 200000
machine.adb.keyboard.press 0x7F
scheduler.run 5000000
# Picker shows two boot devices: ▣2 (floppy) and ▣3 (the parallel-port ProFile).
machine.screen.match expected_startupfrom.png

# === Apple-3 → select the ProFile (▣3); its on-disk loader boots ============
machine.adb.keyboard.press 0xFF
scheduler.run 200000
machine.adb.keyboard.press 0xF2
scheduler.run 200000
machine.adb.keyboard.press 0x72
scheduler.run 200000
machine.adb.keyboard.press 0x7F
# The ProFile's loader reaches its "boot :" prompt (default cmd: pf(0,0)xenix).
scheduler.run 60000000

# === Accept the loader default (pf(0,0)xenix) and boot ======================
# Dummy Return first clears the loader's COPS state-3, then Return boots the
# kernel off the ProFile.  Completing the read depends on the deferred BSY/CA1
# data-ready edge (lisa_profile.c pro_complete); without it this hangs forever.
machine.adb.keyboard.press 0xC8
scheduler.run 300000
machine.adb.keyboard.press 0x48
scheduler.run 5000000
machine.adb.keyboard.press 0xC8
scheduler.run 300000
machine.adb.keyboard.press 0x48

# Xenix boots to its multi-user startup prompt ("Type CONTROL-d to proceed with
# normal startup, / or give root password for system maintenance").
scheduler.run 120000000
machine.screen.match expected_startup.png
quit
