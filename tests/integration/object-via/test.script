# M7c integration: `via1` / `via2` object classes.
# SE/30 has both. The script just walks the tree and reads each
# attribute — the exact register values depend on boot timing, so
# we don't pin them, but each path must resolve to a numeric/JSON
# value with no error JSON.

run 100000

# via1 attributes.
eval via1
via1.ifr
via1.ier
via1.acr
via1.pcr
via1.sr
via1.freq_factor

# via1 port children.
via1.port_a
via1.port_a.output
via1.port_a.input
via1.port_a.direction
via1.port_b.output
via1.port_b.input
via1.port_b.direction

# via2 — only present on SE/30 / IIcx, which is what this test boots.
eval via2
via2.ifr
via2.ier
via2.acr
via2.port_a.output
via2.port_b.direction

# Sanity: via1 and via2 are independent — different freq_factor
# (Plus VIA divisor is 10, SE/30 is 20; via2 tracks its parent VIA's
# divisor, which is the same on Universal ROM machines).
via1.freq_factor
via2.freq_factor

quit
